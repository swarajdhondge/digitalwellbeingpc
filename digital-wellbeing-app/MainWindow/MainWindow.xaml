<Window
    x:Class="digital_wellbeing_app.MainWindow.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Digital Wellbeing"
    Height="750" Width="1100"
    MinHeight="500" MinWidth="800"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="CanResize"
    FontFamily="{DynamicResource Font.Primary}"
    TextOptions.TextFormattingMode="Ideal"
    StateChanged="Window_StateChanged"
    Closing="Window_Closing">

    <!-- Window container with soft shadow -->
    <Border x:Name="WindowBorder"
            Background="{DynamicResource Bg}"
            CornerRadius="8"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ============================================ -->
            <!-- ICON RAIL -->
            <!-- ============================================ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Bg2}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,0,1,0"
                    CornerRadius="8,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Brand mark -->
                    <Border Grid.Row="0" Width="38" Height="38" CornerRadius="11"
                            Margin="0,16,0,10" HorizontalAlignment="Center"
                            Background="{DynamicResource Card2}" ClipToBounds="True"
                            ToolTip="Digital Wellbeing">
                        <Image Source="/Resources/Icons/digital-balance-icon-32.png"
                               Width="38" Height="38"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <!-- Primary navigation -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,6,0,0">
                        <RadioButton x:Name="NavDashboard" Style="{StaticResource Pulse.RailItem}"
                                     GroupName="Rail" IsChecked="True" Click="Dashboard_Click"
                                     ToolTip="Today" AutomationProperties.AutomationId="NavDashboard"
                                     AutomationProperties.Name="Today">
                            <md:PackIcon Kind="ViewDashboardOutline" Width="22" Height="22"/>
                        </RadioButton>
                        <RadioButton x:Name="NavScreen" Style="{StaticResource Pulse.RailItem}"
                                     GroupName="Rail" Click="ScreenTime_Click"
                                     ToolTip="Screen time" AutomationProperties.AutomationId="NavScreen"
                                     AutomationProperties.Name="Screen time">
                            <md:PackIcon Kind="MonitorDashboard" Width="22" Height="22"/>
                        </RadioButton>
                        <RadioButton x:Name="NavApps" Style="{StaticResource Pulse.RailItem}"
                                     GroupName="Rail" Click="AppUsage_Click"
                                     ToolTip="App usage" AutomationProperties.AutomationId="NavApps"
                                     AutomationProperties.Name="App usage">
                            <md:PackIcon Kind="ViewGridOutline" Width="22" Height="22"/>
                        </RadioButton>
                        <RadioButton x:Name="NavSound" Style="{StaticResource Pulse.RailItem}"
                                     GroupName="Rail" Click="Sound_Click"
                                     ToolTip="Hearing" AutomationProperties.AutomationId="NavSound"
                                     AutomationProperties.Name="Hearing">
                            <md:PackIcon Kind="VolumeHigh" Width="22" Height="22"/>
                        </RadioButton>
                        <RadioButton x:Name="NavFocus" Style="{StaticResource Pulse.RailItem}"
                                     GroupName="Rail" Click="Focus_Click"
                                     ToolTip="Focus" AutomationProperties.AutomationId="NavFocus"
                                     AutomationProperties.Name="Focus">
                            <md:PackIcon Kind="Target" Width="22" Height="22"/>
                        </RadioButton>
                        <RadioButton x:Name="NavReports" Style="{StaticResource Pulse.RailItem}"
                                     GroupName="Rail" Click="Reports_Click"
                                     ToolTip="Insights" AutomationProperties.AutomationId="NavReports"
                                     AutomationProperties.Name="Insights">
                            <md:PackIcon Kind="ChartBoxOutline" Width="22" Height="22"/>
                        </RadioButton>
                    </StackPanel>

                    <!-- Footer navigation -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <Border Height="1" Width="34" Background="{DynamicResource Border}" Margin="0,6,0,8"/>

                        <RadioButton x:Name="NavSettings" Style="{StaticResource Pulse.RailItem}"
                                     GroupName="Rail" Click="Settings_Click"
                                     ToolTip="Settings" AutomationProperties.AutomationId="NavSettings"
                                     AutomationProperties.Name="Settings">
                            <md:PackIcon Kind="CogOutline" Width="22" Height="22"/>
                        </RadioButton>
                        <RadioButton x:Name="NavHelp" Style="{StaticResource Pulse.RailItem}"
                                     GroupName="Rail" Click="Help_Click"
                                     ToolTip="Help" AutomationProperties.AutomationId="NavHelp"
                                     AutomationProperties.Name="Help">
                            <md:PackIcon Kind="HelpCircleOutline" Width="22" Height="22"/>
                        </RadioButton>
                        <Button Style="{StaticResource Pulse.Button.Icon}" Width="46" Height="46"
                                Margin="0,3" HorizontalAlignment="Center" Click="Exit_Click"
                                ToolTip="Exit" AutomationProperties.Name="Exit">
                            <md:PackIcon Kind="LogoutVariant" Width="20" Height="20"/>
                        </Button>

                        <TextBlock x:Name="SidebarVersionText"
                                   Text="v2.5.0"
                                   FontSize="9"
                                   Foreground="{DynamicResource Ink3}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- CONTENT AREA -->
            <!-- ============================================ -->
            <Border Grid.Column="1"
                    Background="{DynamicResource Bg}"
                    CornerRadius="0,8,8,0">
                <Grid>
                    <!-- Faint single-hue radial wash behind everything -->
                    <Border IsHitTestVisible="False" Opacity="0.10">
                        <Border.Background>
                            <RadialGradientBrush GradientOrigin="0.5,0" Center="0.5,0" RadiusX="1.0" RadiusY="0.8">
                                <GradientStop Color="{DynamicResource Accent.Color}" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="0.65"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ===== TOP BAR (draggable) ===== -->
                        <Grid Grid.Row="0" Background="Transparent" Margin="26,16,14,8"
                              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                              MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Title + tracking + subtitle -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TitleText" Style="{StaticResource Pulse.PageTitle}"
                                               Text="Today" VerticalAlignment="Center"
                                               AutomationProperties.AutomationId="PageTitle"/>
                                    <Border x:Name="TrackingPill" Style="{StaticResource Pulse.Pill.Good}" Margin="14,4,0,0"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Style="{StaticResource Pulse.Dot}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Tracking" Margin="6,0,0,0" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{StaticResource Good}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="SubtitleText" Style="{StaticResource Pulse.Subtitle}"
                                           Text="Your day at a glance" Margin="0,3,0,0"/>
                            </StackPanel>

                            <!-- Right cluster: theme toggle, privacy pill, window controls -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="ThemeToggleButton" Style="{StaticResource Pulse.Button.Icon}"
                                        Click="ThemeToggle_Click" ToolTip="Switch theme"
                                        AutomationProperties.AutomationId="ThemeToggle">
                                    <md:PackIcon x:Name="ThemeToggleIcon" Kind="WeatherSunny" Width="20" Height="20"/>
                                </Button>

                                <Button Click="Settings_Click" Cursor="Hand" Margin="8,0,14,0"
                                        Foreground="{DynamicResource Ink}" Background="{DynamicResource Accent.Soft}"
                                        ToolTip="Open settings" AutomationProperties.AutomationId="PrivatePill"
                                        AutomationProperties.Name="Private on-device">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="pb" Background="{TemplateBinding Background}"
                                                    CornerRadius="999" Padding="11,7">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="pb" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="ShieldCheckOutline" Width="16" Height="16"
                                                     Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Private &#183; on-device" Margin="7,0,0,0" FontSize="12"
                                                   FontWeight="Medium" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="MinimizeButton" Style="{StaticResource Pulse.Button.Icon}"
                                        Width="36" Height="36" Click="MinimizeButton_Click" ToolTip="Minimize">
                                    <md:PackIcon Kind="WindowMinimize" Width="15" Height="15"/>
                                </Button>
                                <Button x:Name="MaximizeButton" Style="{StaticResource Pulse.Button.Icon}"
                                        Width="36" Height="36" Click="MaximizeButton_Click" ToolTip="Maximize">
                                    <md:PackIcon x:Name="MaximizeIcon" Kind="WindowMaximize" Width="15" Height="15"/>
                                </Button>
                                <Button x:Name="CloseButton" Style="{StaticResource Pulse.Button.Icon}"
                                        Width="36" Height="36" Click="CloseButton_Click" ToolTip="Close">
                                    <md:PackIcon Kind="WindowClose" Width="15" Height="15"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- ===== HOSTED VIEW ===== -->
                        <ContentControl x:Name="MainContent"
                                        Grid.Row="1"
                                        Style="{StaticResource AnimatedContentControl}"
                                        AutomationProperties.AutomationId="MainContent"
                                        Margin="0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- RESIZE GRIP -->
            <!-- ============================================ -->
            <Grid Grid.Column="1"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,4,4"
                  Cursor="SizeNWSE"
                  Width="16" Height="16"
                  Background="Transparent"
                  MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown">
                <Path Data="M 0,12 L 12,0 M 4,12 L 12,4 M 8,12 L 12,8"
                      Stroke="{DynamicResource Ink3}"
                      StrokeThickness="1.5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Margin="2"/>
            </Grid>

            <!-- ============================================ -->
            <!-- WIND DOWN MODE VISUAL CUE -->
            <!-- ============================================ -->
            <Border x:Name="WindDownBorder"
                    Grid.ColumnSpan="2"
                    BorderThickness="4"
                    BorderBrush="#F59E0B"
                    CornerRadius="8"
                    Opacity="0.3"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Panel.ZIndex="500">
                <Border.Effect>
                    <BlurEffect Radius="8"/>
                </Border.Effect>
            </Border>

            <!-- ============================================ -->
            <!-- BREAK REMINDER OVERLAY -->
            <!-- ============================================ -->
            <Grid x:Name="BreakOverlay"
                  Grid.ColumnSpan="2"
                  Visibility="Collapsed"
                  Panel.ZIndex="1000">

                <Border x:Name="BreakBackdrop"
                        Background="#80000000"
                        MouseLeftButtonDown="BreakBackdrop_Click"/>

                <Border Style="{StaticResource Pulse.Card}"
                        Padding="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="400"
                        MaxWidth="500">
                    <StackPanel>
                        <md:PackIcon Kind="Eye" Width="48" Height="48"
                                     Foreground="{DynamicResource Accent}"
                                     HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Time for a break!"
                                   Style="{StaticResource Pulse.CardTitle}" FontSize="22"
                                   TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Follow the 20-20-20 rule: Look at something 20 feet away for 20 seconds."
                                   Style="{StaticResource Pulse.Body2}"
                                   TextAlignment="Center" Margin="0,0,0,32"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="OverlayDismissButton"
                                    Content="Dismiss"
                                    Click="OverlayDismissButton_Click"
                                    Style="{StaticResource Pulse.Button.Ghost}"
                                    Padding="24,11" Margin="0,0,12,0"/>
                            <Button x:Name="OverlaySnoozeButton"
                                    Content="Snooze 5 min"
                                    Click="OverlaySnoozeButton_Click"
                                    Style="{StaticResource Pulse.Button.Primary}"
                                    Padding="24,11"/>
                        </StackPanel>
                        <TextBlock x:Name="TurnOffLink"
                                   Text="Turn off reminders"
                                   Foreground="{DynamicResource Ink2}"
                                   TextDecorations="Underline"
                                   HorizontalAlignment="Center"
                                   Margin="0,24,0,0"
                                   FontSize="13"
                                   Cursor="Hand"
                                   MouseLeftButtonDown="TurnOffLink_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ============================================ -->
            <!-- FOCUS MODE WARNING OVERLAY -->
            <!-- ============================================ -->
            <Grid x:Name="FocusWarningOverlay"
                  Grid.ColumnSpan="2"
                  Visibility="Collapsed"
                  Panel.ZIndex="1001">

                <Border x:Name="FocusBackdrop"
                        Background="#80000000"
                        MouseLeftButtonDown="FocusBackdrop_Click"/>

                <Border Style="{StaticResource Pulse.Card}"
                        Padding="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="420"
                        MaxWidth="520">
                    <StackPanel>
                        <md:PackIcon Kind="AlertCircle" Width="48" Height="48"
                                     Foreground="{StaticResource Warn}"
                                     HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Focus Mode Active"
                                   Style="{StaticResource Pulse.CardTitle}" FontSize="22"
                                   TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock x:Name="DistractingAppName"
                                   Text="Chrome"
                                   Style="{StaticResource Pulse.CardTitle}"
                                   Foreground="{StaticResource Danger}"
                                   TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="This app is marked as Entertainment. Stay focused on your work!"
                                   Style="{StaticResource Pulse.Body2}"
                                   TextAlignment="Center" Margin="0,0,0,32"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BackToWorkButton"
                                    Content="Back to Work"
                                    Click="BackToWorkButton_Click"
                                    Style="{StaticResource Pulse.Button.Primary}"
                                    Padding="24,11" Margin="0,0,12,0"/>
                            <Button x:Name="ContinueAnywayButton"
                                    Content="Continue Anyway"
                                    Click="ContinueAnywayButton_Click"
                                    Style="{StaticResource Pulse.Button.Ghost}"
                                    Padding="24,11"/>
                        </StackPanel>
                        <TextBlock x:Name="FocusTimeRemaining"
                                   Text="24:35 remaining in focus session"
                                   Foreground="{DynamicResource Ink3}"
                                   HorizontalAlignment="Center" Margin="0,24,0,0" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ============================================ -->
            <!-- END SESSION CONFIRMATION OVERLAY -->
            <!-- ============================================ -->
            <Grid x:Name="EndSessionOverlay"
                  Grid.ColumnSpan="2"
                  Visibility="Collapsed"
                  Panel.ZIndex="1002">

                <Border Background="#80000000"
                        MouseLeftButtonDown="EndSessionBackdrop_Click"/>

                <Border Style="{StaticResource Pulse.Card}"
                        Padding="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="400"
                        MaxWidth="480">
                    <StackPanel>
                        <md:PackIcon Kind="TimerOff" Width="48" Height="48"
                                     Foreground="{StaticResource Warn}"
                                     HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="End Focus Session?"
                                   Style="{StaticResource Pulse.CardTitle}" FontSize="22"
                                   TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock x:Name="EndSessionMessage"
                                   Text="You still have 15:30 remaining. Are you sure you want to end early?"
                                   Style="{StaticResource Pulse.Body2}"
                                   TextAlignment="Center" Margin="0,0,0,32"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="KeepGoingButton"
                                    Content="Keep Going"
                                    Click="KeepGoingButton_Click"
                                    Style="{StaticResource Pulse.Button.Primary}"
                                    Padding="24,11" Margin="0,0,12,0"/>
                            <Button x:Name="ConfirmEndSessionButton"
                                    Content="End Session"
                                    Click="ConfirmEndSessionButton_Click"
                                    Style="{StaticResource Pulse.Button.Ghost}"
                                    Padding="24,11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
