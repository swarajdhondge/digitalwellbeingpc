<UserControl x:Class="digital_wellbeing_app.Views.Reports.WeeklyReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vm="clr-namespace:digital_wellbeing_app.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="900"
             FontFamily="{DynamicResource Font.Primary}"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:WeeklyReportViewModel/>
    </UserControl.DataContext>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                  Padding="26,4,26,26">
        <StackPanel MaxWidth="1040" HorizontalAlignment="Stretch">

            <!-- Week nav -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding WeekLabel}" Style="{StaticResource Pulse.CardTitle}" FontSize="15" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource Pulse.Button.Icon}" Width="34" Height="34"
                            Command="{Binding PreviousWeekCommand}" ToolTip="Previous week">
                        <md:PackIcon Kind="ChevronLeft" Width="20" Height="20"/>
                    </Button>
                    <Button Style="{StaticResource Pulse.Button.Icon}" Width="34" Height="34"
                            Command="{Binding NextWeekCommand}" IsEnabled="{Binding CanNavigateNext}" ToolTip="Next week">
                        <md:PackIcon Kind="ChevronRight" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Hero: daily average + trend chart -->
            <Border Style="{StaticResource Pulse.Card}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="DAILY AVERAGE" Style="{StaticResource Pulse.Eyebrow}"/>
                            <TextBlock Text="{Binding AverageDailyTime}" Style="{StaticResource Pulse.Stat}" Margin="0,6,0,0"/>
                            <TextBlock Text="Daily average screen time" Style="{StaticResource Pulse.Body2}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" VerticalAlignment="Top">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Pulse.Pill.Warn}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScreenTimeImproved}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Good.Soft}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ChangePercent}" FontSize="12" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Warn}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ScreenTimeImproved}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Good}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <Border Margin="0,18,0,0" Height="180">
                        <lvc:CartesianChart Series="{Binding DailyTrendSeries}"
                                            XAxes="{Binding DailyTrendXAxes}"
                                            YAxes="{Binding DailyTrendYAxes}"
                                            TooltipPosition="Top"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Total + comparison -->
            <Border Style="{StaticResource Pulse.Card}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TOTAL SCREEN TIME" Style="{StaticResource Pulse.Eyebrow}"/>
                        <TextBlock Text="{Binding TotalScreenTime}" Style="{StaticResource Pulse.CardTitle}" FontSize="22" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource Warn}"/>
                                    <Setter Property="Text" Value="{Binding ChangePercent}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScreenTimeImproved}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource Good}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="vs last week" Style="{StaticResource Pulse.Body2}" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Most used apps -->
            <TextBlock Text="Most used apps" Style="{StaticResource Pulse.CardTitle}" FontSize="14" Margin="2,4,0,10"/>
            <Border Style="{StaticResource Pulse.Card}" Margin="0,0,0,16">
                <ItemsControl ItemsSource="{Binding TopApps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding AppName}" Style="{StaticResource Pulse.Body}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FormattedTime}" Style="{StaticResource Pulse.Body2}"/>
                                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                    <Border Style="{StaticResource Pulse.ProgressTrack}" Height="6"/>
                                    <Border Background="{DynamicResource Accent}" CornerRadius="999" Height="6" HorizontalAlignment="Left">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                                <Binding Path="PercentOfMax"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Focus vs leisure -->
            <TextBlock Text="Focus vs leisure" Style="{StaticResource Pulse.CardTitle}" FontSize="14" Margin="2,4,0,10"/>
            <Border Style="{StaticResource Pulse.Card}" Margin="0,0,0,16">
                <StackPanel>
                    <Border CornerRadius="6" Height="22" ClipToBounds="True" Margin="0,0,0,18" Background="{DynamicResource Track}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding FocusPercent, Converter={StaticResource PercentToGridLength}}"/>
                                <ColumnDefinition Width="{Binding LeisurePercent, Converter={StaticResource PercentToGridLength}}"/>
                                <ColumnDefinition Width="{Binding OtherPercent, Converter={StaticResource PercentToGridLength}}"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource Good}"/>
                            <Border Grid.Column="1" Background="{StaticResource Warn}"/>
                            <Border Grid.Column="2" Background="{DynamicResource Ink3}"/>
                        </Grid>
                    </Border>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="4" Height="20" CornerRadius="2" Background="{StaticResource Good}" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="Focus (Work)" Style="{StaticResource Pulse.Body}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding FocusTime}" Style="{StaticResource Pulse.Body2}" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="4" Height="20" CornerRadius="2" Background="{StaticResource Warn}" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="Leisure" Style="{StaticResource Pulse.Body}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding LeisureTime}" Style="{StaticResource Pulse.Body2}" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="4" Height="20" CornerRadius="2" Background="{DynamicResource Ink3}" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="Other" Style="{StaticResource Pulse.Body}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding OtherTime}" Style="{StaticResource Pulse.Body2}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Focus sessions summary -->
            <Border Style="{StaticResource Pulse.Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11" Background="{StaticResource Accent.Focus.Soft}">
                        <md:PackIcon Kind="Target" Width="20" Height="20" Foreground="{StaticResource Accent.Focus}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="Focus sessions" Style="{StaticResource Pulse.CardTitle}" FontSize="15"/>
                        <TextBlock Text="Completed this week" Style="{StaticResource Pulse.Body2}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding FocusSessionCount}" Style="{StaticResource Pulse.CardTitle}" FontSize="22" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
