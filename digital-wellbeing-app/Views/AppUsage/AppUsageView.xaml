<UserControl
    x:Class="digital_wellbeing_app.Views.AppUsage.AppUsageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:digital_wellbeing_app.ViewModels"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:conv="clr-namespace:digital_wellbeing_app.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="800" d:DesignWidth="900"
    FontFamily="{DynamicResource Font.Primary}"
    Background="Transparent">

    <UserControl.DataContext>
        <vm:AppUsageViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <conv:DurationToWidthConverter x:Key="DurationToWidthConverter"/>
    </UserControl.Resources>

    <ScrollViewer x:Name="PageScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="26,4,26,26">
        <StackPanel x:Name="PageRoot" HorizontalAlignment="Center">

            <!-- Now using -->
            <Border Style="{StaticResource Pulse.Card}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Pulse.IconTile}" Width="48" Height="48"
                            Background="{DynamicResource Accent.Soft}" Margin="0,0,16,0">
                        <Image Source="{Binding CurrentAppIcon}" Width="28" Height="28" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="NOW USING" Style="{StaticResource Pulse.Eyebrow}"/>
                        <TextBlock Text="{Binding CurrentAppName}" Style="{StaticResource Pulse.CardTitle}" Margin="0,3,0,0"/>
                        <TextBlock Text="{Binding CurrentWindowTitle}" Style="{StaticResource Pulse.Muted}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="320" HorizontalAlignment="Left" Margin="0,2,0,0"
                                   Visibility="{Binding HasCurrentApp, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentAppDuration}" Style="{StaticResource Pulse.CardTitle}" FontSize="20"
                                   VerticalAlignment="Center"/>
                        <Ellipse Width="7" Height="7" Fill="{StaticResource Good}" Margin="9,0,0,0" VerticalAlignment="Center"
                                 Visibility="{Binding HasCurrentApp, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.3" Duration="0:0:0.8" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Quick stats -->
            <Border Style="{StaticResource Pulse.Card}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SwitchCount}" Style="{StaticResource Pulse.CardTitle}" FontSize="22" HorizontalAlignment="Center"/>
                        <TextBlock Text="App switches" Style="{StaticResource Pulse.Body2}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding AverageFocusTime}" Style="{StaticResource Pulse.CardTitle}" FontSize="22" HorizontalAlignment="Center"/>
                        <TextBlock Text="Avg focus" Style="{StaticResource Pulse.Body2}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding LongestSessionTime}" Style="{StaticResource Pulse.CardTitle}" FontSize="22" HorizontalAlignment="Center"/>
                        <TextBlock Text="Longest focus" Style="{StaticResource Pulse.Body2}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Today's apps -->
            <TextBlock Text="Today's apps" Style="{StaticResource Pulse.CardTitle}" FontSize="14" Margin="2,0,0,10"/>

            <Border Style="{StaticResource Pulse.Card}"
                    Visibility="{Binding HasApps, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding TodaysUsage}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                                        Background="{DynamicResource Card2}" Margin="0,0,12,0">
                                    <Image Source="{Binding Icon}" Width="24" Height="24" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{Binding AppName}" Style="{StaticResource Pulse.Body}"/>
                                    <Border Height="6" Margin="0,6,0,0" Style="{StaticResource Pulse.ProgressTrack}">
                                        <Border Background="{DynamicResource Accent}" CornerRadius="999" Height="6"
                                                HorizontalAlignment="Left"
                                                Width="{Binding TotalDuration, Converter={StaticResource DurationToWidthConverter}}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding DurationFormatted}" Style="{StaticResource Pulse.Body2}"
                                           VerticalAlignment="Center" MinWidth="60" TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Empty state -->
            <Border Style="{StaticResource Pulse.Card}" Padding="40"
                    Visibility="{Binding HasApps, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                <StackPanel HorizontalAlignment="Center">
                    <md:PackIcon Kind="ApplicationOutline" Width="44" Height="44" Foreground="{DynamicResource Ink3}"
                                 HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <TextBlock Text="No apps tracked yet" Style="{StaticResource Pulse.CardTitle}" FontSize="15"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Start using some applications and they'll appear here."
                               Style="{StaticResource Pulse.Body2}" HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
