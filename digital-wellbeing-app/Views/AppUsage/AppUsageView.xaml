<UserControl
    x:Class="digital_wellbeing_app.Views.AppUsage.AppUsageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:digital_wellbeing_app.ViewModels"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:conv="clr-namespace:digital_wellbeing_app.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="800" d:DesignWidth="900"
    FontFamily="{DynamicResource Font.Primary}"
    Background="Transparent">

    <UserControl.DataContext>
        <vm:AppUsageViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <conv:DurationToWidthConverter x:Key="DurationToWidthConverter"/>
    </UserControl.Resources>

    <ScrollViewer x:Name="PageScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="26,4,26,26">
        <StackPanel x:Name="PageRoot" HorizontalAlignment="Center">

            <!-- Today / Week segmented toggle -->
            <Border Style="{StaticResource Pulse.SegmentBar}" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Today" AutomationProperties.AutomationId="AppRangeToday"
                                 Style="{StaticResource Pulse.Segment}" GroupName="AppRange" IsChecked="True"
                                 Checked="TodayRange_Checked"/>
                    <RadioButton Content="Week" AutomationProperties.AutomationId="AppRangeWeek"
                                 Style="{StaticResource Pulse.Segment}" GroupName="AppRange"
                                 Checked="WeekRange_Checked"/>
                </StackPanel>
            </Border>

            <!-- Now using -->
            <Border Style="{StaticResource Pulse.Card}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="54" Height="54" CornerRadius="13"
                            Background="{DynamicResource Accent.Soft}" Margin="0,0,16,0">
                        <Image Source="{Binding CurrentAppIcon}" Width="30" Height="30" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="NOW USING" Style="{StaticResource Pulse.Eyebrow}"/>
                        <TextBlock Text="{Binding CurrentAppName}" FontSize="17" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Ink}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentAppDuration}" Style="{StaticResource Pulse.Stat}" FontSize="22"
                                   VerticalAlignment="Center"/>
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource Accent}" Margin="10,0,0,0" VerticalAlignment="Center"
                                 Visibility="{Binding HasCurrentApp, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3 stat tiles (separate cards) -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Pulse.Card}" Padding="20" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding SwitchCount}" Style="{StaticResource Pulse.Stat}" FontSize="28"/>
                        <TextBlock Text="App switches" Style="{StaticResource Pulse.Body2}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Pulse.Card}" Padding="20" Margin="8,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding AverageFocusTime}" Style="{StaticResource Pulse.Stat}" FontSize="28"/>
                        <TextBlock Text="Avg focus" Style="{StaticResource Pulse.Body2}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Pulse.Card}" Padding="20" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding LongestSessionTime}" Style="{StaticResource Pulse.Stat}" FontSize="28"/>
                        <TextBlock Text="Longest focus" Style="{StaticResource Pulse.Body2}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Today's apps -->
            <Border Style="{StaticResource Pulse.Card}"
                    Visibility="{Binding HasApps, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding RangeHeader}" Style="{StaticResource Pulse.Eyebrow}" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding TodaysUsage}" AlternationCount="6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                                            Background="{DynamicResource Card2}" Margin="0,0,14,0">
                                        <Image Source="{Binding Icon}" Width="24" Height="24" Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding AppName}" Style="{StaticResource Pulse.Body}" Margin="0,0,0,7"/>
                                        <Border Height="5" CornerRadius="3" Background="{DynamicResource Track}">
                                            <Border Height="5" CornerRadius="3" HorizontalAlignment="Left"
                                                    Background="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={StaticResource ColorIndexToTint}}"
                                                    Width="{Binding TotalDuration, Converter={StaticResource DurationToWidthConverter}}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding DurationFormatted}" FontSize="13.5"
                                               Foreground="{DynamicResource Ink}" VerticalAlignment="Center" MinWidth="56" TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <Border Style="{StaticResource Pulse.Card}" Padding="40"
                    Visibility="{Binding HasApps, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                <StackPanel HorizontalAlignment="Center">
                    <md:PackIcon Kind="ApplicationOutline" Width="44" Height="44" Foreground="{DynamicResource Ink3}"
                                 HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <TextBlock Text="No apps tracked yet" Style="{StaticResource Pulse.CardTitle}" FontSize="15"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Start using some applications and they'll appear here."
                               Style="{StaticResource Pulse.Body2}" HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
