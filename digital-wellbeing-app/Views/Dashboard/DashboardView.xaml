<UserControl x:Class="digital_wellbeing_app.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="820" d:DesignWidth="1000"
             FontFamily="{DynamicResource Font.Primary}"
             Background="Transparent">

    <ScrollViewer x:Name="DashScroll" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                  Padding="26,0,26,26" SizeChanged="DashScroll_SizeChanged">
        <Grid x:Name="RootGrid" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <!-- ===================== LEFT COLUMN ===================== -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">

                <!-- HERO -->
                <Border Style="{StaticResource Pulse.Card}" Padding="28" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Day ring -->
                        <Grid Grid.Column="0" Width="200" Height="200" Margin="0,0,30,0">
                            <Ellipse Width="200" Height="200" Stroke="{DynamicResource Track}" StrokeThickness="18"/>
                            <Ellipse Width="200" Height="200" StrokeThickness="18"
                                     StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                     RenderTransformOrigin="0.5,0.5"
                                     StrokeDashArray="{Binding RingFraction, Converter={StaticResource FractionToDash}, ConverterParameter=31.76}">
                                <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Stroke" Value="{DynamicResource Accent}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOverGoal}" Value="True">
                                                <Setter Property="Stroke" Value="{StaticResource Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ScreenTime}" Style="{StaticResource Pulse.Stat}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding GoalText}" Style="{StaticResource Pulse.Muted}" HorizontalAlignment="Center"
                                           TextAlignment="Center" MaxWidth="160" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Right of ring -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="TODAY · SCREEN TIME" Style="{StaticResource Pulse.Eyebrow}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Border Style="{StaticResource Pulse.Pill}" Background="{DynamicResource Card2}"
                                        BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                        Visibility="{Binding HasVsYesterday, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="TrendingUp" Width="14" Height="14" Foreground="{DynamicResource Ink3}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding VsYesterdayText}" Margin="6,0,0,0" FontSize="12.5" Foreground="{DynamicResource Ink2}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <md:PackIcon Kind="ChartTimelineVariant" Width="14" Height="14" Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding WeeklyChangeText}" Margin="6,0,0,0" FontSize="12.5" Foreground="{DynamicResource Ink2}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="Split across your top apps" Style="{StaticResource Pulse.Body2}" Margin="0,18,0,9"/>
                            <Border CornerRadius="8" ClipToBounds="True" Height="16">
                                <ItemsControl ItemsSource="{Binding TopApps}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="16" Margin="0,0,3,0" CornerRadius="7"
                                                    Background="{Binding ColorIndex, Converter={StaticResource ColorIndexToTint}}">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                                        <Binding Path="Percentage"/>
                                                        <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <ItemsControl ItemsSource="{Binding TopApps}" Margin="0,16,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,18,9">
                                            <Border Width="9" Height="9" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,8,0"
                                                    Background="{Binding ColorIndex, Converter={StaticResource ColorIndexToTint}}"/>
                                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{DynamicResource Ink}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Duration}" FontSize="12.5" Foreground="{DynamicResource Ink3}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- THIS WEEK (rose) -->
                <Border Background="{StaticResource Accent.Weekly.Soft}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        CornerRadius="{StaticResource Radius.XL}" Padding="24" Effect="{DynamicResource Shadow.Card}"
                        Cursor="Hand" Margin="0,0,0,16" MouseLeftButtonUp="WeeklySummary_Click">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="THIS WEEK" Style="{StaticResource Pulse.Eyebrow}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding WeekTotalText}" Style="{StaticResource Pulse.Stat}" FontSize="25"/>
                                    <TextBlock Text="{Binding WeekAvgText, StringFormat=' · {0}/day avg'}" Style="{StaticResource Pulse.Body2}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource Card2}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                    CornerRadius="999" Padding="13,8" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Insights" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Accent.Weekly}" VerticalAlignment="Center"/>
                                    <md:PackIcon Kind="ArrowTopRight" Width="15" Height="15" Foreground="{StaticResource Accent.Weekly}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <!-- Bar chart -->
                        <ItemsControl ItemsSource="{Binding WeekBars}" Height="138">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" VerticalAlignment="Bottom" Height="{Binding HeightPx}"
                                                CornerRadius="7,7,3,3" Background="{StaticResource Accent.Weekly}" Opacity="{Binding Opacity}"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Label}" HorizontalAlignment="Center" Margin="0,8,0,0"
                                                   FontSize="11" Foreground="{DynamicResource Ink3}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- PAIR: Hearing + Categories -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hearing (teal) -->
                    <Border Grid.Column="0" Background="{StaticResource Accent.Sound.Soft}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                            CornerRadius="{StaticResource Radius.XL}" Padding="22" Effect="{DynamicResource Shadow.Card}"
                            Cursor="Hand" Margin="0,0,8,0" MouseLeftButtonUp="Hearing_Click">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="HEARING" Style="{StaticResource Pulse.Eyebrow}"/>
                                <Border Grid.Column="1" Style="{StaticResource Pulse.Pill.Good}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Style="{StaticResource Pulse.Dot}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SoundStatus}" Margin="6,0,0,0" FontSize="11.5" Foreground="{StaticResource Good}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="62" Height="62" Margin="0,0,16,0">
                                    <Ellipse Width="62" Height="62" Stroke="{DynamicResource Track}" StrokeThickness="7"/>
                                    <Ellipse Width="62" Height="62" Stroke="{StaticResource Accent.Sound}" StrokeThickness="7" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                             RenderTransformOrigin="0.5,0.5" StrokeDashArray="3.5,100">
                                        <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                                    </Ellipse>
                                </Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SoundTime}" Style="{StaticResource Pulse.Stat}" FontSize="21"/>
                                    <TextBlock Text="loud listening" Style="{StaticResource Pulse.Muted}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Categories (orchid) -->
                    <Border Grid.Column="1" Background="{StaticResource Accent.Appusage.Soft}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                            CornerRadius="{StaticResource Radius.XL}" Padding="22" Effect="{DynamicResource Shadow.Card}" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="CATEGORIES" Style="{StaticResource Pulse.Eyebrow}" Margin="0,0,0,14"/>
                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,11">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="26" Height="26" CornerRadius="8" Background="{Binding Tint}" Margin="0,0,10,0">
                                                <md:PackIcon Kind="{Binding Icon}" Width="14" Height="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" Foreground="{DynamicResource Ink}" VerticalAlignment="Center"/>
                                            <Border Grid.Column="2" Width="56" Height="6" CornerRadius="3" Background="{DynamicResource Track}" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <Border HorizontalAlignment="Left" Height="6" CornerRadius="3" Background="{Binding Tint}"
                                                        Width="{Binding BarFraction, Converter={StaticResource FractionToWidth}, ConverterParameter=56}"/>
                                            </Border>
                                            <TextBlock Grid.Column="3" Text="{Binding Duration}" FontSize="12" Foreground="{DynamicResource Ink3}" VerticalAlignment="Center" MinWidth="40" TextAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- ===================== RIGHT COLUMN ===================== -->
            <StackPanel Grid.Column="1">

                <!-- Most used (orchid) -->
                <Border Background="{StaticResource Accent.Appusage.Soft}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        CornerRadius="{StaticResource Radius.XL}" Padding="22" Effect="{DynamicResource Shadow.Card}"
                        Cursor="Hand" Margin="0,0,0,16" MouseLeftButtonUp="MostUsed_Click">
                    <StackPanel>
                        <TextBlock Text="MOST USED TODAY" Style="{StaticResource Pulse.Eyebrow}" Margin="0,0,0,14"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="{StaticResource Accent.Appusage.Soft}" Margin="0,0,14,0">
                                <Image Source="{Binding TopAppIcon}" Width="28" Height="28" RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TopAppName}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource Ink}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding TopAppDuration}" Style="{StaticResource Pulse.Stat}" FontSize="20" VerticalAlignment="Center"/>
                        </Grid>
                        <Viewbox Height="46" Stretch="Fill" HorizontalAlignment="Stretch">
                            <Canvas Width="280" Height="46">
                                <Polygon Points="{Binding SparkArea}" Fill="{StaticResource Accent.Appusage.Soft}"/>
                                <Polyline Points="{Binding SparkLine}" Stroke="{StaticResource Accent.Appusage}" StrokeThickness="2.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <!-- Enter Focus (amber) -->
                <Border Background="{StaticResource Accent.Focus.Soft}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        CornerRadius="{StaticResource Radius.XL}" Padding="22" Effect="{DynamicResource Shadow.Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="11" HorizontalAlignment="Left" Background="{StaticResource Accent.Focus.Soft}">
                            <md:PackIcon Kind="Target" Width="21" Height="21" Foreground="{StaticResource Accent.Focus}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Enter Focus" Style="{StaticResource Pulse.Stat}" FontSize="19" Margin="0,14,0,6"/>
                        <TextBlock Text="Silence distractions and protect a block of deep work." Style="{StaticResource Pulse.Body2}" Margin="0,0,0,18"/>
                        <Button Style="{StaticResource Pulse.Button.Primary}" Background="{StaticResource Accent.Focus}"
                                HorizontalAlignment="Stretch" Click="EnterFocus_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Start a session" VerticalAlignment="Center"/>
                                <md:PackIcon Kind="ArrowRight" Width="17" Height="17" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Daily goal (cyan) -->
                <Border Background="{StaticResource Accent.Screentime.Soft}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        CornerRadius="{StaticResource Radius.XL}" Padding="22" Effect="{DynamicResource Shadow.Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="DAILY GOAL" Style="{StaticResource Pulse.Eyebrow}"/>
                            <TextBlock Grid.Column="1" Text="{Binding GoalText}" Style="{StaticResource Pulse.Muted}" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Height="9" Margin="0,0,0,14">
                            <Border x:Name="GoalTrack" Height="9" CornerRadius="999" Background="{DynamicResource Track}"/>
                            <Border Height="9" CornerRadius="999" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource Accent.Screentime}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOverGoal}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource GoalProgressToWidthConverter}">
                                        <Binding Path="RingFraction"/>
                                        <Binding ElementName="GoalTrack" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="MoonWaningCrescent" Width="16" Height="16" Foreground="{DynamicResource Ink3}" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource Pulse.Body2}" FontSize="12.5" VerticalAlignment="Center" Margin="8,0,0,0">
                                <Run Text="Set a goal in "/><Run Text="Settings" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
