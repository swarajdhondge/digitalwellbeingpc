<UserControl
    x:Class="digital_wellbeing_app.Views.Help.HelpView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    FontFamily="{DynamicResource Font.Primary}"
    Background="Transparent">

    <UserControl.Resources>
        <!-- Section-tinted FAQ card -->
        <Style x:Key="FaqCard" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource Radius.XL}"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect" Value="{DynamicResource Shadow.Card}"/>
        </Style>
        <Style x:Key="FaqIcon" TargetType="Border">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FaqTitle" TargetType="TextBlock" BasedOn="{StaticResource Pulse.CardTitle}">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FaqBody" TargetType="TextBlock" BasedOn="{StaticResource Pulse.Body2}">
            <Setter Property="Margin" Value="0,12,0,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="PageScroll" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                  Padding="26,4,26,26">
        <StackPanel x:Name="PageRoot" HorizontalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <!-- Today (indigo) -->
                    <Border Style="{StaticResource FaqCard}" Background="{StaticResource Accent.Dashboard.Soft}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource FaqIcon}" Background="{StaticResource Accent.Dashboard.Soft}">
                                    <md:PackIcon Kind="ViewDashboardOutline" Width="18" Height="18" Foreground="{StaticResource Accent.Dashboard}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Today" Style="{StaticResource FaqTitle}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource FaqBody}"
                                       Text="The summary of your day. The hero stat is total active screen time — time spent actively using your PC. Idle periods aren't counted. Tinted cards preview each section and link straight to it."/>
                        </StackPanel>
                    </Border>

                    <!-- App usage (orchid) -->
                    <Border Style="{StaticResource FaqCard}" Background="{StaticResource Accent.Appusage.Soft}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource FaqIcon}" Background="{StaticResource Accent.Appusage.Soft}">
                                    <md:PackIcon Kind="ViewGridOutline" Width="18" Height="18" Foreground="{StaticResource Accent.Appusage}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="App usage" Style="{StaticResource FaqTitle}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource FaqBody}"
                                       Text="Records which app has focus and for how long. App names are stored, but window titles are never saved to the database for privacy. Categorize apps as Work, Entertainment or Neutral for Focus."/>
                        </StackPanel>
                    </Border>

                    <!-- Focus &amp; Wind Down (amber) -->
                    <Border Style="{StaticResource FaqCard}" Background="{StaticResource Accent.Focus.Soft}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource FaqIcon}" Background="{StaticResource Accent.Focus.Soft}">
                                    <md:PackIcon Kind="Target" Width="18" Height="18" Foreground="{StaticResource Accent.Focus}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Focus &amp; Wind Down" Style="{StaticResource FaqTitle}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource FaqBody}"
                                       Text="Focus sessions watch for Entertainment apps. Warn shows a popup; Block minimizes them. Wind Down adds a gentle glowing border on your schedule (Amber, Purple or Dim) to signal it's time to wrap up."/>
                        </StackPanel>
                    </Border>

                    <!-- Break reminders (indigo) -->
                    <Border Style="{StaticResource FaqCard}" Background="{StaticResource Accent.Dashboard.Soft}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource FaqIcon}" Background="{StaticResource Accent.Dashboard.Soft}">
                                    <md:PackIcon Kind="Eye" Width="18" Height="18" Foreground="{StaticResource Accent.Dashboard}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Break reminders" Style="{StaticResource FaqTitle}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource FaqBody}"
                                       Text="Follows the 20-20-20 rule: every 20 minutes, look 20 feet away for 20 seconds. Snooze up to 3 times; the timer resets after a natural idle break. Reminders appear in the title bar."/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT COLUMN -->
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <!-- Screen time (cyan) -->
                    <Border Style="{StaticResource FaqCard}" Background="{StaticResource Accent.Screentime.Soft}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource FaqIcon}" Background="{StaticResource Accent.Screentime.Soft}">
                                    <md:PackIcon Kind="MonitorDashboard" Width="18" Height="18" Foreground="{StaticResource Accent.Screentime}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Screen time" Style="{StaticResource FaqTitle}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource FaqBody}"
                                       Text="Tracks how long your display is on while you're active (mouse/keyboard input within 60s). Step away and it pauses on idle. The timeline shows your day; the weekly view shows daily totals."/>
                        </StackPanel>
                    </Border>

                    <!-- Hearing (teal) -->
                    <Border Style="{StaticResource FaqCard}" Background="{StaticResource Accent.Sound.Soft}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource FaqIcon}" Background="{StaticResource Accent.Sound.Soft}">
                                    <md:PackIcon Kind="VolumeHigh" Width="18" Height="18" Foreground="{StaticResource Accent.Sound}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Hearing" Style="{StaticResource FaqTitle}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource FaqBody}"
                                       Text="Estimates listening level from the system audio meter — it never records or listens to actual audio. The WHO suggests staying under 85 dB; the default harmful threshold is 75 dB. Bars over 75 dB are shown in red."/>
                        </StackPanel>
                    </Border>

                    <!-- Insights (rose) -->
                    <Border Style="{StaticResource FaqCard}" Background="{StaticResource Accent.Weekly.Soft}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource FaqIcon}" Background="{StaticResource Accent.Weekly.Soft}">
                                    <md:PackIcon Kind="ChartBoxOutline" Width="18" Height="18" Foreground="{StaticResource Accent.Weekly}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Insights" Style="{StaticResource FaqTitle}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource FaqBody}"
                                       Text="Aggregates the past 7 days: screen-time trends, top apps, focus completion and sound levels. Week-over-week comparisons show whether your habits are improving; focus vs. leisure shows how productive your time was."/>
                        </StackPanel>
                    </Border>

                    <!-- Privacy (steel) -->
                    <Border Style="{StaticResource FaqCard}" Background="{StaticResource Accent.Settings.Soft}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource FaqIcon}" Background="{StaticResource Accent.Settings.Soft}">
                                    <md:PackIcon Kind="ShieldCheckOutline" Width="18" Height="18" Foreground="{StaticResource Accent.Settings}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Privacy" Style="{StaticResource FaqTitle}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource FaqBody}"
                                       Text="Everything stays on this device — no account, no cloud, no telemetry. Export your data as CSV or delete it all from Settings at any time."/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Footer links -->
            <Border Background="{DynamicResource Accent.Soft}" CornerRadius="{StaticResource Radius.MD}" Padding="16,14" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <md:PackIcon Kind="BugOutline" Width="16" Height="16" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="ReportBugLink" Text="Report a bug" Style="{StaticResource Pulse.Body2}" Foreground="{DynamicResource Accent}"
                                   TextDecorations="Underline" Cursor="Hand" MouseLeftButtonDown="ReportBug_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Github" Width="16" Height="16" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="GitHubLink" Text="View on GitHub" Style="{StaticResource Pulse.Body2}" Foreground="{DynamicResource Accent}"
                                   TextDecorations="Underline" Cursor="Hand" MouseLeftButtonDown="GitHub_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
