<UserControl
    x:Class="digital_wellbeing_app.Views.Screen.ScreenView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:conv="clr-namespace:digital_wellbeing_app.Converters"
    mc:Ignorable="d"
    d:DesignHeight="800" d:DesignWidth="500"
    Background="Transparent">

    <UserControl.Resources>
        <conv:TimelineWidthConverter    x:Key="TimelineWidthConverter" />
        <conv:HourToOffsetConverter     x:Key="HourToOffsetConverter" />
        <conv:HourDynamicLabelConverter x:Key="HourDynamicLabelConverter" />
        <conv:HourVisibilityConverter   x:Key="HourVisibilityConverter" />
        <conv:UsageToWidthConverter     x:Key="UsageToWidthConverter" />
        <conv:TrackingStateToTextConverter  x:Key="StateToTextConverter" />
        <conv:TrackingStateToColorConverter x:Key="StateToColorConverter" />
        <conv:GoalProgressToColorConverter  x:Key="GoalProgressToColorConverter" />
        <conv:GoalProgressToWidthConverter  x:Key="GoalProgressToWidthConverter" />
        <conv:BoolToVisibilityConverter     x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="20,16">
        <StackPanel>

            <!-- ============================================ -->
            <!-- PAGE HEADER -->
            <!-- ============================================ -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Screen time"
                           Style="{StaticResource HeadingLarge}"/>

                <!-- Status Indicator -->
                <Border Grid.Column="1"
                        Background="{DynamicResource Bg.Card}"
                        CornerRadius="{DynamicResource Radius.Full}"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Fill="{Binding TrackingState, Converter={StaticResource StateToColorConverter}}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TrackingState, Converter={StaticResource StateToTextConverter}}"
                                   Style="{StaticResource LabelSecondary}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ============================================ -->
            <!-- VIEW TOGGLE (Today / Weekly view) -->
            <!-- ============================================ -->
            <StackPanel Style="{StaticResource ViewToggleContainer}">
                <TextBlock x:Name="TodayToggle"
                           Text="Today"
                           MouseLeftButtonDown="TodayToggle_Click"
                           Cursor="Hand">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource ToggleActive}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWeeklyView}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Style="{StaticResource ViewToggleSeparator}"/>
                <TextBlock x:Name="WeeklyToggle"
                           Text="Weekly view"
                           MouseLeftButtonDown="WeeklyToggle_Click"
                           Cursor="Hand">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource ToggleInactive}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWeeklyView}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- ============================================ -->
            <!-- HERO STAT CARD -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardBase}"
                    Margin="{StaticResource Margin.Card}">
                <StackPanel>
                    <!-- Hero Time -->
                    <TextBlock Text="{Binding TodayTimeText}"
                               Style="{StaticResource StatNumber}"
                               HorizontalAlignment="Left"/>
                    
                    <!-- Subtitle -->
                    <TextBlock Text="{Binding ContextLine}"
                               Style="{StaticResource StatLabel}"
                               Margin="0,4,0,0"/>

                    <!-- ============================================ -->
                    <!-- HOURLY COLUMN CHART (Samsung Blue Bars) -->
                    <!-- ============================================ -->
                    <Border x:Name="TimelineBorder"
                            Margin="0,24,0,0"
                            Height="120">
                        <Grid>
                            <!-- Chart Area -->
                            <Canvas x:Name="RealTimeCanvas" Background="Transparent"/>
                            
                            <!-- Goal Line (Red Dashed) - if goal is set -->
                            <Border Style="{StaticResource GoalLineContainer}"
                                    VerticalAlignment="Top"
                                    Margin="0,30,0,0"
                                    Visibility="{Binding HasGoal, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- Hour Labels -->
                    <ItemsControl ItemsSource="{Binding HourMarkers}"
                                  Margin="0,4,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="24"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource ChartAxisLabel}"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource HourDynamicLabelConverter}">
                                            <Binding/>
                                            <Binding ElementName="TimelineBorder" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                    <TextBlock.Visibility>
                                        <MultiBinding Converter="{StaticResource HourVisibilityConverter}">
                                            <Binding/>
                                            <Binding ElementName="TimelineBorder" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ============================================ -->
            <!-- GOAL PROGRESS CARD -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardBase}" 
                    Margin="{StaticResource Margin.Card}"
                    Visibility="{Binding HasGoal, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Daily goal"
                                   Style="{StaticResource SectionHeader}"
                                   Margin="0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding GoalProgressText}"
                                   Style="{StaticResource ValueDisplay}"/>
                    </Grid>
                    
                    <!-- Progress Bar -->
                    <Border x:Name="GoalProgressContainer"
                            Background="{DynamicResource Bg.Elevated}"
                            CornerRadius="{DynamicResource Radius.Full}"
                            Height="8">
                        <Border Background="{Binding GoalProgress, Converter={StaticResource GoalProgressToColorConverter}}"
                                CornerRadius="{DynamicResource Radius.Full}"
                                HorizontalAlignment="Left">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource GoalProgressToWidthConverter}">
                                    <Binding Path="GoalProgress"/>
                                    <Binding ElementName="GoalProgressContainer" Path="ActualWidth"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============================================ -->
            <!-- QUICK STATS CARD -->
            <!-- ============================================ -->
            <Border Style="{StaticResource CardBase}"
                    Margin="{StaticResource Margin.Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sessions -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SessionCount}"
                                   Style="{StaticResource ValueDisplay}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Sessions"
                                   Style="{StaticResource LabelSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Longest -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding LongestSession}"
                                   Style="{StaticResource ValueDisplay}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Longest"
                                   Style="{StaticResource LabelSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Breaks -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding BreakCount}"
                                   Style="{StaticResource ValueDisplay}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Breaks"
                                   Style="{StaticResource LabelSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- WEEKLY USAGE SECTION -->
            <!-- ============================================ -->

            <!-- Week Navigation Header -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevWeekBtn"
                        Grid.Column="0"
                        Click="PrevWeek_Click"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Width="32" Height="32"
                        Padding="0"
                        Foreground="{DynamicResource Text.Secondary}">
                    <md:PackIcon Kind="ChevronLeft" Width="20" Height="20"/>
                </Button>

                <TextBlock Grid.Column="1"
                           Text="{Binding WeekLabel}"
                           Style="{StaticResource SectionHeader}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0"/>

                <Button x:Name="NextWeekBtn"
                        Grid.Column="2"
                        Click="NextWeek_Click"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Width="32" Height="32"
                        Padding="0"
                        IsEnabled="{Binding CanGoForward}"
                        Foreground="{DynamicResource Text.Secondary}">
                    <md:PackIcon Kind="ChevronRight" Width="20" Height="20"/>
                </Button>
            </Grid>

            <Border Style="{StaticResource CardBase}">
                <StackPanel>
                    <!-- Weekly Average -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Daily average"
                                   Style="{StaticResource LabelSecondary}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding WeeklyAverageText}"
                                   Style="{StaticResource ValueDisplay}"/>
                    </Grid>

                    <!-- Day-by-day list -->
                    <ItemsControl ItemsSource="{Binding WeeklyUsage}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Day Name -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Day}"
                                               Style="{StaticResource ListItemName}"
                                               VerticalAlignment="Center">
                                        <TextBlock.FontWeight>
                                            <Binding Path="IsToday">
                                                <Binding.Converter>
                                                    <conv:BoolToFontWeightConverter/>
                                                </Binding.Converter>
                                            </Binding>
                                        </TextBlock.FontWeight>
                                    </TextBlock>

                                    <!-- Progress Bar -->
                                    <Border x:Name="WeekBarContainer"
                                            Grid.Column="1"
                                            Background="{DynamicResource Bg.Elevated}"
                                            CornerRadius="{DynamicResource Radius.Full}"
                                            Height="8"
                                            Margin="12,0"
                                            VerticalAlignment="Center">
                                        <Border Background="{DynamicResource Chart.Primary}"
                                                CornerRadius="{DynamicResource Radius.Full}"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                                    <Binding Path="Percentage"/>
                                                    <Binding ElementName="WeekBarContainer" Path="ActualWidth"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>

                                    <!-- Duration -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Usage}"
                                               Style="{StaticResource ListItemDuration}"
                                               VerticalAlignment="Center"
                                               MinWidth="60"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Timeline Legend -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Border Width="12" Height="12" 
                            Background="{DynamicResource Chart.Primary}"
                            CornerRadius="2"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="Active"
                               Style="{StaticResource LabelSecondary}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               ToolTip="Time spent actively using your PC (mouse/keyboard input)"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="12" Height="12"
                            Background="{DynamicResource Bg.Elevated}"
                            CornerRadius="2"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="Idle"
                               Style="{StaticResource LabelSecondary}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               ToolTip="Time with no mouse/keyboard input detected"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
