<UserControl
    x:Class="digital_wellbeing_app.Views.Screen.ScreenView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:conv="clr-namespace:digital_wellbeing_app.Converters"
    mc:Ignorable="d"
    d:DesignHeight="800" d:DesignWidth="900"
    FontFamily="{DynamicResource Font.Primary}"
    Background="Transparent">

    <UserControl.Resources>
        <conv:HourDynamicLabelConverter x:Key="HourDynamicLabelConverter" />
        <conv:HourVisibilityConverter   x:Key="HourVisibilityConverter" />
        <conv:BoolToFontWeightConverter x:Key="BoolToFontWeight" />
    </UserControl.Resources>

    <ScrollViewer x:Name="ScreenScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="26,4,26,26" SizeChanged="ScreenScroll_SizeChanged">
        <StackPanel x:Name="RootPanel" HorizontalAlignment="Center">

            <!-- Today / Week segmented toggle -->
            <Border Style="{StaticResource Pulse.SegmentBar}" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="TodayToggle" Content="Today" Style="{StaticResource Pulse.Segment}"
                                 GroupName="ScreenRange" Click="TodayToggle_Click"
                                 IsChecked="{Binding IsWeeklyView, Converter={StaticResource InverseBool}, Mode=OneWay}"/>
                    <RadioButton x:Name="WeeklyToggle" Content="Week" Style="{StaticResource Pulse.Segment}"
                                 GroupName="ScreenRange" Click="WeeklyToggle_Click"
                                 IsChecked="{Binding IsWeeklyView, Mode=OneWay}"/>
                </StackPanel>
            </Border>

            <!-- ============ TODAY ============ -->
            <StackPanel Visibility="{Binding IsWeeklyView, Converter={StaticResource InverseBoolToVisibility}}">

                <!-- Hero: active screen time + 24h timeline -->
                <Border Style="{StaticResource Pulse.Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ACTIVE SCREEN TIME" Style="{StaticResource Pulse.Eyebrow}"/>
                        <TextBlock Text="{Binding TodayTimeText}" Style="{StaticResource Pulse.Stat}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding ContextLine}" Style="{StaticResource Pulse.Body2}" Margin="0,2,0,0"/>

                        <Border x:Name="TimelineBorder" Margin="0,22,0,0" Height="100">
                            <Border Background="{DynamicResource Track}" CornerRadius="14" Padding="0,8">
                                <Canvas x:Name="RealTimeCanvas" Background="Transparent"/>
                            </Border>
                        </Border>

                        <ItemsControl ItemsSource="{Binding HourMarkers}" Margin="0,6,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Rows="1" Columns="24"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center" FontSize="10"
                                               Foreground="{DynamicResource Ink3}">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource HourDynamicLabelConverter}">
                                                <Binding/>
                                                <Binding ElementName="TimelineBorder" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                        <TextBlock.Visibility>
                                            <MultiBinding Converter="{StaticResource HourVisibilityConverter}">
                                                <Binding/>
                                                <Binding ElementName="TimelineBorder" Path="ActualWidth"/>
                                            </MultiBinding>
                                        </TextBlock.Visibility>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Goal progress (only when a goal is set) -->
                <Border Style="{StaticResource Pulse.Card}" Margin="0,0,0,16"
                        Visibility="{Binding HasGoal, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Daily goal" Style="{StaticResource Pulse.CardTitle}" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="{Binding GoalProgressText}" Style="{StaticResource Pulse.Body2}"/>
                        </Grid>
                        <Grid Height="8">
                            <Border x:Name="GoalProgressContainer" Style="{StaticResource Pulse.ProgressTrack}"/>
                            <Border Height="8" CornerRadius="999" HorizontalAlignment="Left"
                                    Background="{Binding GoalProgress, Converter={StaticResource GoalProgressToColorConverter}}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource GoalProgressToWidthConverter}">
                                        <Binding Path="GoalProgress"/>
                                        <Binding ElementName="GoalProgressContainer" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Quick stats -->
                <Border Style="{StaticResource Pulse.Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding SessionCount}" Style="{StaticResource Pulse.CardTitle}" FontSize="22"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Sessions" Style="{StaticResource Pulse.Body2}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding LongestSession}" Style="{StaticResource Pulse.CardTitle}" FontSize="22"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Longest stretch" Style="{StaticResource Pulse.Body2}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding BreakCount}" Style="{StaticResource Pulse.CardTitle}" FontSize="22"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Breaks taken" Style="{StaticResource Pulse.Body2}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ============ WEEK ============ -->
            <StackPanel Visibility="{Binding IsWeeklyView, Converter={StaticResource BoolToVisibilityConverter}}">

                <!-- Week nav -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="PrevWeekBtn" Grid.Column="0" Click="PrevWeek_Click"
                            Style="{StaticResource Pulse.Button.Icon}" Width="34" Height="34">
                        <md:PackIcon Kind="ChevronLeft" Width="20" Height="20"/>
                    </Button>
                    <TextBlock Grid.Column="1" Text="{Binding WeekLabel}" Style="{StaticResource Pulse.CardTitle}"
                               FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button x:Name="NextWeekBtn" Grid.Column="2" Click="NextWeek_Click" IsEnabled="{Binding CanGoForward}"
                            Style="{StaticResource Pulse.Button.Icon}" Width="34" Height="34">
                        <md:PackIcon Kind="ChevronRight" Width="20" Height="20"/>
                    </Button>
                </Grid>

                <Border Style="{StaticResource Pulse.Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Daily average" Style="{StaticResource Pulse.Body2}"/>
                            <TextBlock Grid.Column="1" Text="{Binding WeeklyAverageText}" Style="{StaticResource Pulse.CardTitle}" FontSize="16"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding WeeklyUsage}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Day}" Style="{StaticResource Pulse.Body}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="{Binding IsToday, Converter={StaticResource BoolToFontWeight}}"/>
                                        <Border x:Name="WeekBarContainer" Grid.Column="1" Height="8" Margin="12,0"
                                                VerticalAlignment="Center" Style="{StaticResource Pulse.ProgressTrack}">
                                            <Border Background="{DynamicResource Accent}" CornerRadius="999" HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                                        <Binding Path="Percentage"/>
                                                        <Binding ElementName="WeekBarContainer" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Usage}" Style="{StaticResource Pulse.Body2}"
                                                   VerticalAlignment="Center" MinWidth="60" TextAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
