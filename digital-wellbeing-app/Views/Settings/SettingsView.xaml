<UserControl
    x:Class="digital_wellbeing_app.Views.Settings.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">

            <!-- Page Header -->
            <TextBlock Text="Settings"
                       Style="{StaticResource HeadingLarge}"
                       Margin="0,0,0,24"/>

            <!-- Screen Time Goal Section (Phase 3.3) -->
            <TextBlock Text="SCREEN TIME GOAL"
                       Style="{StaticResource NavSectionHeader}"
                       Margin="0,0,0,12"/>

            <Border Style="{StaticResource CardBase}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Daily Limit"
                               Style="{StaticResource HeadingSmall}"
                               Margin="0,0,0,12"/>
                    
                    <TextBlock Text="Set a target for your daily screen time. You'll see progress on the Screen Time page."
                               Style="{StaticResource LabelSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <!-- Goal Toggle -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Enable daily goal"
                                   Style="{StaticResource BodyMedium}"
                                   VerticalAlignment="Center"/>

                        <ToggleButton x:Name="GoalEnabledCheckBox"
                                      Grid.Column="1"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      Checked="GoalEnabledCheckBox_Changed"
                                      Unchecked="GoalEnabledCheckBox_Changed"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Goal Input -->
                    <StackPanel x:Name="GoalInputPanel" 
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                            <TextBox x:Name="GoalHoursTextBox"
                                     Width="60"
                                     Padding="12,8"
                                     TextAlignment="Center"
                                     FontSize="16"
                                     Background="{DynamicResource Bg.Elevated}"
                                     Foreground="{DynamicResource Text.Primary}"
                                     BorderThickness="0"
                                     TextChanged="GoalInput_Changed"/>
                            <TextBlock Text="hours"
                                       Style="{StaticResource LabelSecondary}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="GoalMinutesTextBox"
                                     Width="60"
                                     Padding="12,8"
                                     TextAlignment="Center"
                                     FontSize="16"
                                     Background="{DynamicResource Bg.Elevated}"
                                     Foreground="{DynamicResource Text.Primary}"
                                     BorderThickness="0"
                                     TextChanged="GoalInput_Changed"/>
                            <TextBlock Text="minutes"
                                       Style="{StaticResource LabelSecondary}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Current Goal Display -->
                    <TextBlock x:Name="CurrentGoalText"
                               Style="{StaticResource LabelMuted}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Break Reminders Section -->
            <TextBlock Text="BREAK REMINDERS"
                       Style="{StaticResource NavSectionHeader}"
                       Margin="0,0,0,12"/>

            <Border Style="{StaticResource CardBase}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Regular Breaks"
                               Style="{StaticResource HeadingSmall}"
                               Margin="0,0,0,12"/>
                    
                    <TextBlock Text="Get reminded to take breaks and rest your eyes. Follow the 20-20-20 rule: every 20 minutes, look at something 20 feet away for 20 seconds."
                               Style="{StaticResource LabelSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <!-- Enable Toggle -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Enable break reminders"
                                   Style="{StaticResource BodyMedium}"
                                   VerticalAlignment="Center"/>

                        <ToggleButton x:Name="BreakReminderToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      Checked="BreakReminderToggle_Changed"
                                      Unchecked="BreakReminderToggle_Changed"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Interval Selection -->
                    <StackPanel x:Name="BreakReminderOptionsPanel" 
                                Visibility="Collapsed"
                                Margin="0,0,0,16">
                        <TextBlock Text="Reminder interval"
                                   Style="{StaticResource BodyMedium}"
                                   Margin="0,0,0,8"/>
                        
                        <ComboBox x:Name="IntervalComboBox"
                                  SelectionChanged="IntervalComboBox_SelectionChanged"
                                  Background="{DynamicResource Bg.Elevated}"
                                  Foreground="{DynamicResource Text.Primary}"
                                  BorderThickness="0"
                                  Padding="12,8">
                            <ComboBoxItem Content="Every 15 minutes" Tag="15"/>
                            <ComboBoxItem Content="Every 20 minutes (recommended)" Tag="20" IsSelected="True"/>
                            <ComboBoxItem Content="Every 30 minutes" Tag="30"/>
                            <ComboBoxItem Content="Every 45 minutes" Tag="45"/>
                            <ComboBoxItem Content="Every 60 minutes" Tag="60"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Sound Toggle -->
                    <Grid x:Name="BreakReminderSoundPanel" 
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Play notification sound"
                                   Style="{StaticResource BodyMedium}"
                                   VerticalAlignment="Center"/>

                        <ToggleButton x:Name="SoundToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="True"
                                      Checked="SoundToggle_Changed"
                                      Unchecked="SoundToggle_Changed"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Info -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <md:PackIcon Kind="Information" Width="16" Height="16"
                                     Foreground="{DynamicResource Text.Muted}"
                                     VerticalAlignment="Center"/>
                        <TextBlock Text="Notifications appear in the title bar. You can snooze or dismiss them."
                                   Style="{StaticResource LabelSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Wind Down Mode Section -->
            <TextBlock Text="WIND DOWN MODE"
                       Style="{StaticResource NavSectionHeader}"
                       Margin="0,0,0,12"/>

            <Border Style="{StaticResource CardBase}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Quiet Hours"
                               Style="{StaticResource HeadingSmall}"
                               Margin="0,0,0,12"/>
                    
                    <TextBlock Text="Get a gentle reminder when it's time to wind down for the day. A subtle visual cue will appear around your screen edges during quiet hours."
                               Style="{StaticResource LabelSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <!-- Enable Toggle -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Enable Wind Down mode"
                                   Style="{StaticResource BodyMedium}"
                                   VerticalAlignment="Center"/>

                        <ToggleButton x:Name="WindDownToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      Checked="WindDownToggle_Changed"
                                      Unchecked="WindDownToggle_Changed"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Wind Down Options Panel -->
                    <StackPanel x:Name="WindDownOptionsPanel" 
                                Visibility="Collapsed">
                        
                        <!-- Schedule -->
                        <TextBlock Text="Schedule"
                                   Style="{StaticResource BodyMedium}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Start Time -->
                            <TextBlock Text="From"
                                       Style="{StaticResource BodyMedium}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            
                            <ComboBox x:Name="StartTimeComboBox"
                                      Grid.Column="1"
                                      SelectionChanged="StartTimeComboBox_SelectionChanged"
                                      Background="{DynamicResource Bg.Elevated}"
                                      Foreground="{DynamicResource Text.Primary}"
                                      BorderThickness="0"
                                      Padding="12,8"
                                      MinWidth="100"/>

                            <!-- End Time -->
                            <TextBlock Text="to"
                                       Grid.Column="2"
                                       Style="{StaticResource BodyMedium}"
                                       VerticalAlignment="Center"
                                       Margin="16,0,8,0"/>
                            
                            <ComboBox x:Name="EndTimeComboBox"
                                      Grid.Column="3"
                                      SelectionChanged="EndTimeComboBox_SelectionChanged"
                                      Background="{DynamicResource Bg.Elevated}"
                                      Foreground="{DynamicResource Text.Primary}"
                                      BorderThickness="0"
                                      Padding="12,8"
                                      MinWidth="100"/>
                        </Grid>

                        <!-- Notification Toggle -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Show notification"
                                           Style="{StaticResource BodyMedium}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Display a reminder when Wind Down starts"
                                           Style="{StaticResource LabelMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <ToggleButton x:Name="WindDownNotificationToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="True"
                                          Checked="WindDownNotificationToggle_Changed"
                                          Unchecked="WindDownNotificationToggle_Changed"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Visual Cue Toggle -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Show visual border"
                                           Style="{StaticResource BodyMedium}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Display a subtle glow around the window edges"
                                           Style="{StaticResource LabelMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <ToggleButton x:Name="WindDownVisualToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="True"
                                          Checked="WindDownVisualToggle_Changed"
                                          Unchecked="WindDownVisualToggle_Changed"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Visual Style Selection -->
                        <StackPanel x:Name="VisualStylePanel" Margin="0,8,0,0">
                            <TextBlock Text="Visual style"
                                       Style="{StaticResource BodyMedium}"
                                       Margin="0,0,0,8"/>
                            
                            <StackPanel Orientation="Horizontal">
                                <!-- Amber Style -->
                                <Border x:Name="AmberStyleOption"
                                        Background="{DynamicResource Accent.Primary}"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        Margin="0,0,8,0"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="AmberStyle_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="16" Height="16" 
                                                CornerRadius="8"
                                                Background="#F59E0B"
                                                Margin="0,0,8,0"/>
                                        <TextBlock Text="Amber"
                                                   Style="{StaticResource BodySmall}"
                                                   Foreground="{DynamicResource Accent.OnAccent}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Purple Style -->
                                <Border x:Name="PurpleStyleOption"
                                        Background="{DynamicResource Bg.Elevated}"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        Margin="0,0,8,0"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="PurpleStyle_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="16" Height="16" 
                                                CornerRadius="8"
                                                Background="#8B5CF6"
                                                Margin="0,0,8,0"/>
                                        <TextBlock Text="Purple"
                                                   Style="{StaticResource BodySmall}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Dim Style -->
                                <Border x:Name="DimStyleOption"
                                        Background="{DynamicResource Bg.Elevated}"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="DimStyle_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="16" Height="16" 
                                                CornerRadius="8"
                                                Background="#6B7280"
                                                Margin="0,0,8,0"/>
                                        <TextBlock Text="Dim"
                                                   Style="{StaticResource BodySmall}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Current Status -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <md:PackIcon x:Name="WindDownStatusIcon" 
                                     Kind="MoonWaningCrescent" 
                                     Width="16" Height="16"
                                     Foreground="{DynamicResource Text.Muted}"
                                     VerticalAlignment="Center"/>
                        <TextBlock x:Name="WindDownStatusText"
                                   Text="Wind Down is disabled"
                                   Style="{StaticResource LabelSecondary}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Hearing Protection Section (Coming Soon - Blurred) -->
            <TextBlock Text="HEARING PROTECTION"
                       Style="{StaticResource NavSectionHeader}"
                       Margin="0,0,0,12"/>

            <Border Style="{StaticResource CardBase}" Margin="0,0,0,24" IsEnabled="False">
                <Grid>
                    <!-- Content (blurred/disabled) -->
                    <StackPanel Opacity="0.4">
                        <TextBlock Text="Volume Threshold"
                                   Style="{StaticResource HeadingSmall}"
                                   Margin="0,0,0,12"/>
                        
                        <TextBlock Text="Get notified when listening above this level for extended periods."
                                   Style="{StaticResource LabelSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <!-- Slider with value display -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Slider x:Name="ThresholdSlider"
                                    Style="{StaticResource SliderThemed}"
                                    Minimum="60"
                                    Maximum="100"
                                    Value="75"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    IsEnabled="False"
                                    VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1"
                                       x:Name="ThresholdValueText"
                                       Text="75 dB"
                                       Style="{StaticResource HeadingSmall}"
                                       Foreground="{DynamicResource Text.Muted}"
                                       Margin="16,0,0,0"
                                       MinWidth="50"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Scale labels -->
                        <Grid Margin="0,0,66,12">
                            <TextBlock Text="60 dB"
                                       Style="{StaticResource LabelMuted}"
                                       HorizontalAlignment="Left"/>
                            <TextBlock Text="100 dB"
                                       Style="{StaticResource LabelMuted}"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Recommendation -->
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ShieldCheck" Width="16" Height="16"
                                         Foreground="{DynamicResource Text.Muted}"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="Default: 75 dB"
                                       Style="{StaticResource LabelSecondary}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Coming Soon Overlay -->
                    <Border Background="{DynamicResource Bg.Card}" 
                            Opacity="0.7"
                            CornerRadius="8"
                            Margin="-16"/>
                    <TextBlock Text="Coming Soon"
                               Style="{StaticResource LabelSecondary}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Appearance Section -->
            <TextBlock Text="APPEARANCE"
                       Style="{StaticResource NavSectionHeader}"
                       Margin="0,0,0,12"/>

            <Border Style="{StaticResource CardBase}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Theme"
                               Style="{StaticResource HeadingSmall}"
                               Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal">
                        <!-- Light Theme Option -->
                        <Border x:Name="LightThemeOption"
                                Background="{DynamicResource Bg.Elevated}"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                MouseLeftButtonDown="LightTheme_Click">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="WeatherSunny" Width="20" Height="20"
                                             Foreground="{DynamicResource Text.Secondary}"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="Light"
                                           Style="{StaticResource BodyMedium}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Dark Theme Option -->
                        <Border x:Name="DarkThemeOption"
                                Background="{DynamicResource Accent.Primary}"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                MouseLeftButtonDown="DarkTheme_Click">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="WeatherNight" Width="20" Height="20"
                                             Foreground="{DynamicResource Accent.OnAccent}"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="Dark"
                                           Foreground="{DynamicResource Accent.OnAccent}"
                                           FontSize="14"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Auto Theme Option -->
                        <Border x:Name="AutoThemeOption"
                                Background="{DynamicResource Bg.Elevated}"
                                CornerRadius="8"
                                Padding="16,12"
                                Cursor="Hand"
                                MouseLeftButtonDown="AutoTheme_Click">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ThemeLightDark" Width="20" Height="20"
                                             Foreground="{DynamicResource Text.Secondary}"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="Auto"
                                           Style="{StaticResource BodyMedium}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Startup Section -->
            <TextBlock Text="STARTUP"
                       Style="{StaticResource NavSectionHeader}"
                       Margin="0,0,0,12"/>

            <Border Style="{StaticResource CardBase}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Launch on Windows startup"
                                   Style="{StaticResource BodyMedium}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Start Digital Wellbeing when you log in"
                                   Style="{StaticResource LabelSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <ToggleButton x:Name="StartupCheckBox"
                                  Grid.Column="1"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Checked="StartupCheckBox_Checked"
                                  Unchecked="StartupCheckBox_Checked"
                                  VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- About Section -->
            <TextBlock Text="ABOUT"
                       Style="{StaticResource NavSectionHeader}"
                       Margin="0,0,0,12"/>

            <Border Style="{StaticResource CardFlat}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Image Source="/Resources/Icons/digital-balance-icon-32.png"
                               Width="32" Height="32"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Digital Wellbeing"
                                       Style="{StaticResource HeadingSmall}"/>
                            <TextBlock Text="Version 1.5.0"
                                       Style="{StaticResource LabelSecondary}"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Track your screen time, app usage, and audio exposure to maintain a healthy digital lifestyle."
                               Style="{StaticResource BodySmall}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Hidden radio buttons for backward compatibility -->
            <StackPanel Visibility="Collapsed">
                <RadioButton x:Name="LightRadio" Checked="ThemeRadio_Checked"/>
                <RadioButton x:Name="DarkRadio" Checked="ThemeRadio_Checked"/>
                <RadioButton x:Name="AutoRadio" Checked="ThemeRadio_Checked"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
