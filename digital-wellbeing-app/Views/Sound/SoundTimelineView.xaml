<UserControl
    x:Class="digital_wellbeing_app.Views.Sound.SoundTimelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:digital_wellbeing_app.ViewModels"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:conv="clr-namespace:digital_wellbeing_app.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="800" d:DesignWidth="900"
    FontFamily="{DynamicResource Font.Primary}"
    Background="Transparent">

    <UserControl.DataContext>
        <vm:SoundTimelineViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <conv:HourDynamicLabelConverter x:Key="HourDynamicLabelConverter" />
        <conv:HourVisibilityConverter   x:Key="HourVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="26,4,26,26">
        <StackPanel MaxWidth="1040" HorizontalAlignment="Stretch">

            <!-- Hero: loud listening + 24h dB chart -->
            <Border Style="{StaticResource Pulse.Card}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="LOUD LISTENING TIME" Style="{StaticResource Pulse.Eyebrow}"/>
                            <TextBlock Text="{Binding TotalHarmfulText}" Style="{StaticResource Pulse.Stat}" Margin="0,6,0,0"/>
                            <TextBlock Style="{StaticResource Pulse.Body2}" Margin="0,2,0,0">
                                <Run Text="of "/><Run Text="{Binding TotalListeningText, Mode=OneWay}"/><Run Text=" total listening time"/>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource Pulse.Pill.Good}" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Style="{StaticResource Pulse.Dot}" VerticalAlignment="Center"/>
                                <TextBlock Text="Safe levels" Margin="6,0,0,0" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource Good}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- dB bar chart (canvas; bars >75 dB drawn in Danger) -->
                    <Border x:Name="TimelineBorder" Margin="0,22,0,0" Height="100">
                        <Border Background="{DynamicResource Track}" CornerRadius="6" Height="84" VerticalAlignment="Bottom">
                            <Canvas x:Name="RealTimeCanvas" Background="Transparent"/>
                        </Border>
                    </Border>

                    <ItemsControl ItemsSource="{Binding HourMarkers}" Margin="0,6,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Rows="1" Columns="24"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="{DynamicResource Ink3}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource HourDynamicLabelConverter}">
                                            <Binding/>
                                            <Binding ElementName="TimelineBorder" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                    <TextBlock.Visibility>
                                        <MultiBinding Converter="{StaticResource HourVisibilityConverter}">
                                            <Binding/>
                                            <Binding ElementName="TimelineBorder" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Average / comparison -->
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Average level" Style="{StaticResource Pulse.Body2}"/>
                        <TextBlock Grid.Column="1" Text="{Binding AverageSPLText}" Style="{StaticResource Pulse.CardTitle}" FontSize="14"/>
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Compared to yesterday" Style="{StaticResource Pulse.Body2}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ComparisonText}" Style="{StaticResource Pulse.Body2}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Threshold info cards -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Pulse.Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="HARMFUL THRESHOLD" Style="{StaticResource Pulse.Eyebrow}"/>
                        <TextBlock Text="{Binding ThresholdLabel}" Style="{StaticResource Pulse.CardTitle}" FontSize="15" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Pulse.Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="WHO GUIDANCE" Style="{StaticResource Pulse.Eyebrow}"/>
                        <TextBlock Text="Keep under 85 dB" Style="{StaticResource Pulse.CardTitle}" FontSize="15" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Session details -->
            <TextBlock Text="Session details" Style="{StaticResource Pulse.CardTitle}" FontSize="14" Margin="2,0,0,10"/>
            <Border Style="{StaticResource Pulse.Card}">
                <StackPanel>
                    <Button x:Name="ToggleDetailsButton" Content="Show detailed tracking"
                            Click="ToggleDetailsButton_Click" Style="{StaticResource Pulse.Button.Ghost}"
                            HorizontalAlignment="Left" Margin="0,0,0,14"/>

                    <TextBlock Text="{Binding SessionSummaryText}" Style="{StaticResource Pulse.Body2}" Margin="0,0,0,14"/>

                    <ScrollViewer x:Name="SessionsList" MaxHeight="320" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <ItemsControl ItemsSource="{Binding RecentSessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Card2}" CornerRadius="{StaticResource Radius.MD}"
                                            Padding="12" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                                                    Background="{DynamicResource Accent.Soft}" Margin="0,0,12,0">
                                                <md:PackIcon Kind="{Binding DeviceTypeIcon}" Width="20" Height="20"
                                                             Foreground="{DynamicResource Accent}"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DeviceName}" Style="{StaticResource Pulse.Body}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="240"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding DeviceType}" Style="{StaticResource Pulse.Muted}"/>
                                                    <TextBlock Text=" · " Style="{StaticResource Pulse.Muted}"/>
                                                    <TextBlock Text="{Binding SessionLabel}" Style="{StaticResource Pulse.Muted}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Column="2" CornerRadius="{StaticResource Radius.SM}" Padding="9,4" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource Accent.Soft}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding WasHarmful}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource Danger.Soft}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding PeakSPLText}" FontSize="12" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding WasHarmful}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Legend -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Border Width="12" Height="12" Background="{DynamicResource Accent}" CornerRadius="3" VerticalAlignment="Center"/>
                    <TextBlock Text="Safe" Style="{StaticResource Pulse.Body2}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="12" Height="12" Background="{StaticResource Danger}" CornerRadius="3" VerticalAlignment="Center"/>
                    <TextBlock Text="Harmful" Style="{StaticResource Pulse.Body2}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
