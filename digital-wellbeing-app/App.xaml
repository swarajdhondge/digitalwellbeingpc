<Application
    x:Class="digital_wellbeing_app.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:converters="clr-namespace:digital_wellbeing_app.Converters"
    StartupUri="MainWindow/MainWindow.xaml"
    ShutdownMode="OnLastWindowClose">

    <Application.Resources>
        <ResourceDictionary>
            <!-- Global Converters -->
            <converters:PercentageToWidthConverter x:Key="PercentageToWidthConverter"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <converters:IndexToSegmentColorConverter x:Key="IndexToSegmentColorConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:GoalProgressToWidthConverter x:Key="GoalProgressToWidthConverter"/>
            <converters:GoalProgressToColorConverter x:Key="GoalProgressToColorConverter"/>
            <converters:PercentToGridLengthConverter x:Key="PercentToGridLength"/>
            <converters:FractionToDashConverter x:Key="FractionToDash"/>
            <converters:ColorIndexToTintBrushConverter x:Key="ColorIndexToTint"/>

            <ResourceDictionary.MergedDictionaries>

                <!-- MaterialDesign Base (keep for compatibility during transition) -->
                <md:BundledTheme
                    BaseTheme="Inherit"
                    PrimaryColor="DeepPurple"
                    SecondaryColor="Indigo"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />

                <!-- Shared Design Tokens -->
                <ResourceDictionary Source="Styles/Theme.xaml"/>
                
                <!-- Theme Palette (Dark by default - swapped by ThemeService) -->
                <ResourceDictionary x:Name="ThemePalette" Source="Styles/ThemeDark.xaml"/>

                <!-- Component Styles -->
                <ResourceDictionary Source="Styles/Typography.xaml"/>
                <ResourceDictionary Source="Styles/Cards.xaml"/>
                <ResourceDictionary Source="Styles/Components.xaml"/>
                <ResourceDictionary Source="Styles/Buttons.xaml"/>
                <ResourceDictionary Source="Styles/Navigation.xaml"/>
                <ResourceDictionary Source="Styles/States.xaml"/>
                <ResourceDictionary Source="Styles/Dialogs.xaml"/>
                <ResourceDictionary Source="Styles/Transitions.xaml"/>

                <!-- ============================================================
                     Pulse redesign (active design layer).
                     Tokens first, then the palette (swapped at runtime by
                     ThemeService), then the component styles. Merged LAST so
                     Pulse values win on any shared token key. -->
                <ResourceDictionary Source="Styles/Pulse.Tokens.xaml"/>
                <ResourceDictionary x:Name="PulsePalette" Source="Styles/Pulse.Dark.xaml"/>
                <ResourceDictionary Source="Styles/Pulse.Styles.xaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
