<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ============================================
    COMPONENT STYLES — PULSE redesign
    Drop-in replacement for digital-wellbeing-app/Styles/Components.xaml.
    Identical to the original EXCEPT the four hardcoded category-icon
    colors are retinted to the calm Pulse palette. Everything else is
    token-driven and reskins automatically from ThemeDark/ThemeLight.
    ============================================
    -->

    <!-- ============================================ -->
    <!-- STATUS BADGE -->
    <!-- ============================================ -->

    <Style x:Key="PillBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Full}"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="Background" Value="{DynamicResource Status.Success}"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PillBadgeSuccess" TargetType="Border" BasedOn="{StaticResource PillBadge}">
        <Setter Property="Background" Value="{DynamicResource Status.Success}"/>
    </Style>

    <Style x:Key="PillBadgeWarning" TargetType="Border" BasedOn="{StaticResource PillBadge}">
        <Setter Property="Background" Value="{DynamicResource Status.Warning}"/>
    </Style>

    <Style x:Key="PillBadgeDanger" TargetType="Border" BasedOn="{StaticResource PillBadge}">
        <Setter Property="Background" Value="{DynamicResource Status.Danger}"/>
    </Style>

    <Style x:Key="PillBadgeInfo" TargetType="Border" BasedOn="{StaticResource PillBadge}">
        <Setter Property="Background" Value="{DynamicResource Status.Info}"/>
    </Style>

    <Style x:Key="PillBadgeNeutral" TargetType="Border" BasedOn="{StaticResource PillBadge}">
        <Setter Property="Background" Value="{DynamicResource Text.Muted}"/>
    </Style>

    <!-- ============================================ -->
    <!-- VIEW TOGGLE (Today / Weekly view) -->
    <!-- ============================================ -->

    <Style x:Key="ViewToggleContainer" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <Style x:Key="ViewToggleSeparator" TargetType="TextBlock">
        <Setter Property="Text" Value="/"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.MD}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Muted}"/>
        <Setter Property="Margin" Value="8,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ============================================ -->
    <!-- WEEK SELECTOR PILLS -->
    <!-- ============================================ -->

    <Style x:Key="WeekSelectorContainer" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
    </Style>

    <Style x:Key="WeekPill" TargetType="Border">
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Full}"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="WeekPillActive" TargetType="Border" BasedOn="{StaticResource WeekPill}">
        <Setter Property="Background" Value="{DynamicResource Selector.Active}"/>
    </Style>

    <!-- ============================================ -->
    <!-- STACKED HORIZONTAL BAR -->
    <!-- ============================================ -->

    <Style x:Key="StackedBarContainer" TargetType="Border">
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Full}"/>
        <Setter Property="Height" Value="{DynamicResource Chart.StackedBarHeight}"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Background" Value="{DynamicResource Bg.Elevated}"/>
        <Setter Property="Margin" Value="0,16,0,16"/>
    </Style>

    <Style x:Key="StackedBarInner" TargetType="Grid">
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- ============================================ -->
    <!-- COLORED DOT (for app list) -->
    <!-- ============================================ -->

    <Style x:Key="ColorDot" TargetType="Ellipse">
        <Setter Property="Width" Value="{DynamicResource Dot.Size}"/>
        <Setter Property="Height" Value="{DynamicResource Dot.Size}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>

    <Style x:Key="ColorDotTeal" TargetType="Ellipse" BasedOn="{StaticResource ColorDot}">
        <Setter Property="Fill" Value="{DynamicResource Chart.Segment1}"/>
    </Style>

    <Style x:Key="ColorDotBlue" TargetType="Ellipse" BasedOn="{StaticResource ColorDot}">
        <Setter Property="Fill" Value="{DynamicResource Chart.Segment2}"/>
    </Style>

    <Style x:Key="ColorDotPurple" TargetType="Ellipse" BasedOn="{StaticResource ColorDot}">
        <Setter Property="Fill" Value="{DynamicResource Chart.Segment3}"/>
    </Style>

    <!-- ============================================ -->
    <!-- ICON CONTAINER (category list) -->
    <!-- Retinted to the calm Pulse palette (was raw Samsung hues). -->
    <!-- ============================================ -->

    <Style x:Key="IconContainer" TargetType="Border">
        <Setter Property="Width" Value="{DynamicResource IconContainer.Size}"/>
        <Setter Property="Height" Value="{DynamicResource IconContainer.Size}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Icon}"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Video Category (Pulse red) -->
    <Style x:Key="IconContainerVideo" TargetType="Border" BasedOn="{StaticResource IconContainer}">
        <Setter Property="Background" Value="#E5484D"/>
    </Style>

    <!-- Social Category (Pulse cyan) -->
    <Style x:Key="IconContainerSocial" TargetType="Border" BasedOn="{StaticResource IconContainer}">
        <Setter Property="Background" Value="#2BA3C7"/>
    </Style>

    <!-- Productivity Category (Pulse green) -->
    <Style x:Key="IconContainerProductivity" TargetType="Border" BasedOn="{StaticResource IconContainer}">
        <Setter Property="Background" Value="#30A46C"/>
    </Style>

    <!-- Entertainment Category (Pulse orchid) -->
    <Style x:Key="IconContainerEntertainment" TargetType="Border" BasedOn="{StaticResource IconContainer}">
        <Setter Property="Background" Value="#A867D0"/>
    </Style>

    <!-- ============================================ -->
    <!-- CHART COMPONENTS -->
    <!-- ============================================ -->

    <Style x:Key="ChartBar" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Chart.Primary}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.BarTop}"/>
        <Setter Property="Width" Value="{DynamicResource Chart.BarWidth}"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="GoalLine" TargetType="Line">
        <Setter Property="Stroke" Value="{DynamicResource Status.Danger}"/>
        <Setter Property="StrokeThickness" Value="2"/>
        <Setter Property="StrokeDashArray" Value="4,4"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="GoalLineContainer" TargetType="Border">
        <Setter Property="BorderBrush" Value="{DynamicResource Status.Danger}"/>
        <Setter Property="BorderThickness" Value="0,2,0,0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="GoalCheckmark" TargetType="Border">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="{DynamicResource Status.Success}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <!-- ============================================ -->
    <!-- DATE SELECTOR -->
    <!-- ============================================ -->

    <Style x:Key="DateNumber" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource Font.MD}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="8,0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="DateNumberActive" TargetType="Border">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Background" Value="{DynamicResource Selector.Active}"/>
        <Setter Property="Margin" Value="4,0"/>
    </Style>

    <Style x:Key="DateNumberDisabled" TargetType="TextBlock" BasedOn="{StaticResource DateNumber}">
        <Setter Property="Foreground" Value="{DynamicResource Text.Muted}"/>
        <Setter Property="Opacity" Value="0.5"/>
    </Style>

    <!-- ============================================ -->
    <!-- LIST ITEM COMPONENTS -->
    <!-- ============================================ -->

    <Style x:Key="AppListItem" TargetType="Grid">
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="CategoryListItem" TargetType="Grid">
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- ============================================ -->
    <!-- COMPARISON ROW -->
    <!-- ============================================ -->

    <Style x:Key="ComparisonRow" TargetType="Grid">
        <Setter Property="Margin" Value="0,12,0,0"/>
    </Style>

    <!-- ============================================ -->
    <!-- SCREEN ON/OFF BAR -->
    <!-- ============================================ -->

    <Style x:Key="ComparisonBar" TargetType="Border">
        <Setter Property="Height" Value="8"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Full}"/>
        <Setter Property="Margin" Value="0,12,0,8"/>
    </Style>

    <!-- ============================================ -->
    <!-- TIP SECTION -->
    <!-- ============================================ -->

    <Style x:Key="TipContainer" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Accent.Subtle}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.LG}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,16,0,0"/>
    </Style>

</ResourceDictionary>
