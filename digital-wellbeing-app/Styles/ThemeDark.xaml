<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ============================================
    DARK THEME — PULSE redesign (default)
    Calm graphite base · soft solid surfaces · indigo signature accent.
    Drop-in replacement for digital-wellbeing-app/Styles/ThemeDark.xaml.
    Every x:Key matches the original — only values changed.

    NOTE on accent: Pulse gives each section its own signature hue.
    The Accent.* keys below default to the Dashboard indigo. To get the
    full per-section effect, retint Accent.Primary / Accent.Subtle on
    navigation (see reference/section-accents.md). The single-accent
    fallback already looks correct everywhere.
    ============================================
    -->

    <!-- Background Colors (graphite, near-black) -->
    <Color x:Key="Bg.PrimaryColor">#0E1014</Color>        <!-- app background -->
    <Color x:Key="Bg.SecondaryColor">#0A0C0F</Color>      <!-- rail / sidebar (deepest) -->
    <Color x:Key="Bg.CardColor">#16181D</Color>           <!-- card surface -->
    <Color x:Key="Bg.ElevatedColor">#1C1F26</Color>       <!-- hover / elevated / track fill -->

    <!-- Border Colors -->
    <Color x:Key="Border.DefaultColor">#24272E</Color>    <!-- visible 1px card border -->
    <Color x:Key="Border.SubtleColor">#1C1F26</Color>     <!-- faint divider -->

    <!-- Text Colors -->
    <Color x:Key="Text.PrimaryColor">#EDEFF3</Color>      <!-- primary ink -->
    <Color x:Key="Text.SecondaryColor">#99A1AE</Color>    <!-- secondary labels -->
    <Color x:Key="Text.MutedColor">#636A77</Color>        <!-- muted hints -->

    <!-- Accent Colors (Pulse Dashboard indigo) -->
    <Color x:Key="Accent.PrimaryColor">#6C6FE8</Color>    <!-- active toggle / primary action -->
    <Color x:Key="Accent.HoverColor">#8487EE</Color>      <!-- lighter on hover -->
    <Color x:Key="Accent.SubtleColor">#24263C</Color>     <!-- soft tinted icon badge bg -->
    <Color x:Key="Accent.OnAccentColor">#FFFFFF</Color>   <!-- text/icon on accent -->

    <!-- Chart Colors (calm Pulse hues) -->
    <Color x:Key="Chart.PrimaryColor">#6C6FE8</Color>     <!-- indigo - main chart bars -->
    <Color x:Key="Chart.Segment1Color">#23B39A</Color>   <!-- teal - stacked bar -->
    <Color x:Key="Chart.Segment2Color">#2BA3C7</Color>   <!-- cyan - stacked bar -->
    <Color x:Key="Chart.Segment3Color">#A867D0</Color>   <!-- orchid - stacked bar -->

    <!-- Status Colors (semantic: red=harmful, amber=caution, green=good) -->
    <Color x:Key="Status.SuccessColor">#30A46C</Color>   <!-- good -->
    <Color x:Key="Status.WarningColor">#E0A23C</Color>   <!-- caution -->
    <Color x:Key="Status.DangerColor">#E5484D</Color>    <!-- harmful / goal line -->
    <Color x:Key="Status.InfoColor">#4F8CE0</Color>      <!-- info -->

    <!-- Week Selector -->
    <Color x:Key="Selector.ActiveColor">#2A2E37</Color>   <!-- fill when selected -->
    <Color x:Key="Selector.InactiveColor">Transparent</Color>

    <!-- ============================================ -->
    <!-- BRUSHES -->
    <!-- ============================================ -->

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="Bg.Primary" Color="{StaticResource Bg.PrimaryColor}"/>
    <SolidColorBrush x:Key="Bg.Secondary" Color="{StaticResource Bg.SecondaryColor}"/>
    <SolidColorBrush x:Key="Bg.Card" Color="{StaticResource Bg.CardColor}"/>
    <SolidColorBrush x:Key="Bg.Elevated" Color="{StaticResource Bg.ElevatedColor}"/>

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="Border.Default" Color="{StaticResource Border.DefaultColor}"/>
    <SolidColorBrush x:Key="Border.Subtle" Color="{StaticResource Border.SubtleColor}"/>

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="Text.Primary" Color="{StaticResource Text.PrimaryColor}"/>
    <SolidColorBrush x:Key="Text.Secondary" Color="{StaticResource Text.SecondaryColor}"/>
    <SolidColorBrush x:Key="Text.Muted" Color="{StaticResource Text.MutedColor}"/>

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="Accent.Primary" Color="{StaticResource Accent.PrimaryColor}"/>
    <SolidColorBrush x:Key="Accent.Hover" Color="{StaticResource Accent.HoverColor}"/>
    <SolidColorBrush x:Key="Accent.Subtle" Color="{StaticResource Accent.SubtleColor}"/>
    <SolidColorBrush x:Key="Accent.OnAccent" Color="{StaticResource Accent.OnAccentColor}"/>

    <!-- Chart Brushes -->
    <SolidColorBrush x:Key="Chart.Primary" Color="{StaticResource Chart.PrimaryColor}"/>
    <SolidColorBrush x:Key="Chart.Segment1" Color="{StaticResource Chart.Segment1Color}"/>
    <SolidColorBrush x:Key="Chart.Segment2" Color="{StaticResource Chart.Segment2Color}"/>
    <SolidColorBrush x:Key="Chart.Segment3" Color="{StaticResource Chart.Segment3Color}"/>

    <!-- Status Brushes -->
    <SolidColorBrush x:Key="Status.Success" Color="{StaticResource Status.SuccessColor}"/>
    <SolidColorBrush x:Key="Status.Warning" Color="{StaticResource Status.WarningColor}"/>
    <SolidColorBrush x:Key="Status.Danger" Color="{StaticResource Status.DangerColor}"/>
    <SolidColorBrush x:Key="Status.Info" Color="{StaticResource Status.InfoColor}"/>

    <!-- Selector Brushes -->
    <SolidColorBrush x:Key="Selector.Active" Color="{StaticResource Selector.ActiveColor}"/>
    <SolidColorBrush x:Key="Selector.Inactive" Color="{StaticResource Selector.InactiveColor}"/>

    <!-- ============================================ -->
    <!-- SHADOWS (Pulse: soft, subtle elevation) -->
    <!-- ============================================ -->
    <DropShadowEffect x:Key="Shadow.SM" BlurRadius="12" ShadowDepth="4" Direction="270" Opacity="0.35" Color="#000000"/>
    <DropShadowEffect x:Key="Shadow.MD" BlurRadius="28" ShadowDepth="10" Direction="270" Opacity="0.45" Color="#000000"/>
    <DropShadowEffect x:Key="Shadow.LG" BlurRadius="40" ShadowDepth="16" Direction="270" Opacity="0.50" Color="#000000"/>

</ResourceDictionary>
