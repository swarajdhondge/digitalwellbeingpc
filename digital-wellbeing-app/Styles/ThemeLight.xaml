<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ============================================
    LIGHT THEME — PULSE redesign
    Soft neutral light surfaces · indigo signature accent.
    Drop-in replacement for digital-wellbeing-app/Styles/ThemeLight.xaml.
    Same x:Keys as ThemeDark.xaml — swapped at runtime by ThemeService.
    Accents are nudged slightly deeper than dark for legibility on white.
    ============================================
    -->

    <!-- Background Colors (soft off-white) -->
    <Color x:Key="Bg.PrimaryColor">#F3F4F6</Color>        <!-- app background -->
    <Color x:Key="Bg.SecondaryColor">#ECEEF1</Color>      <!-- rail / sidebar -->
    <Color x:Key="Bg.CardColor">#FFFFFF</Color>           <!-- card surface -->
    <Color x:Key="Bg.ElevatedColor">#F2F4F7</Color>       <!-- hover / elevated / track fill -->

    <!-- Border Colors -->
    <Color x:Key="Border.DefaultColor">#E4E7EC</Color>    <!-- visible 1px card border -->
    <Color x:Key="Border.SubtleColor">#EDEFF2</Color>     <!-- faint divider -->

    <!-- Text Colors -->
    <Color x:Key="Text.PrimaryColor">#181B21</Color>      <!-- primary ink -->
    <Color x:Key="Text.SecondaryColor">#59616E</Color>    <!-- secondary labels -->
    <Color x:Key="Text.MutedColor">#8A92A0</Color>        <!-- muted hints -->

    <!-- Accent Colors (Pulse indigo, deeper for light bg) -->
    <Color x:Key="Accent.PrimaryColor">#5256D8</Color>    <!-- active toggle / primary action -->
    <Color x:Key="Accent.HoverColor">#4347C4</Color>      <!-- darker on hover -->
    <Color x:Key="Accent.SubtleColor">#E9EAFB</Color>     <!-- soft tinted icon badge bg -->
    <Color x:Key="Accent.OnAccentColor">#FFFFFF</Color>   <!-- white text on accent -->

    <!-- Chart Colors (calm Pulse hues, deeper for light) -->
    <Color x:Key="Chart.PrimaryColor">#5256D8</Color>     <!-- indigo - main chart bars -->
    <Color x:Key="Chart.Segment1Color">#1FA08A</Color>   <!-- teal - stacked bar -->
    <Color x:Key="Chart.Segment2Color">#2391B5</Color>   <!-- cyan - stacked bar -->
    <Color x:Key="Chart.Segment3Color">#9A55C6</Color>   <!-- orchid - stacked bar -->

    <!-- Status Colors (semantic) -->
    <Color x:Key="Status.SuccessColor">#2A8F5E</Color>   <!-- good -->
    <Color x:Key="Status.WarningColor">#C9882B</Color>   <!-- caution -->
    <Color x:Key="Status.DangerColor">#D43B40</Color>    <!-- harmful / goal line -->
    <Color x:Key="Status.InfoColor">#3F7BD0</Color>      <!-- info -->

    <!-- Week Selector -->
    <Color x:Key="Selector.ActiveColor">#E5E7EB</Color>   <!-- fill when selected -->
    <Color x:Key="Selector.InactiveColor">Transparent</Color>

    <!-- ============================================ -->
    <!-- BRUSHES -->
    <!-- ============================================ -->

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="Bg.Primary" Color="{StaticResource Bg.PrimaryColor}"/>
    <SolidColorBrush x:Key="Bg.Secondary" Color="{StaticResource Bg.SecondaryColor}"/>
    <SolidColorBrush x:Key="Bg.Card" Color="{StaticResource Bg.CardColor}"/>
    <SolidColorBrush x:Key="Bg.Elevated" Color="{StaticResource Bg.ElevatedColor}"/>

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="Border.Default" Color="{StaticResource Border.DefaultColor}"/>
    <SolidColorBrush x:Key="Border.Subtle" Color="{StaticResource Border.SubtleColor}"/>

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="Text.Primary" Color="{StaticResource Text.PrimaryColor}"/>
    <SolidColorBrush x:Key="Text.Secondary" Color="{StaticResource Text.SecondaryColor}"/>
    <SolidColorBrush x:Key="Text.Muted" Color="{StaticResource Text.MutedColor}"/>

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="Accent.Primary" Color="{StaticResource Accent.PrimaryColor}"/>
    <SolidColorBrush x:Key="Accent.Hover" Color="{StaticResource Accent.HoverColor}"/>
    <SolidColorBrush x:Key="Accent.Subtle" Color="{StaticResource Accent.SubtleColor}"/>
    <SolidColorBrush x:Key="Accent.OnAccent" Color="{StaticResource Accent.OnAccentColor}"/>

    <!-- Chart Brushes -->
    <SolidColorBrush x:Key="Chart.Primary" Color="{StaticResource Chart.PrimaryColor}"/>
    <SolidColorBrush x:Key="Chart.Segment1" Color="{StaticResource Chart.Segment1Color}"/>
    <SolidColorBrush x:Key="Chart.Segment2" Color="{StaticResource Chart.Segment2Color}"/>
    <SolidColorBrush x:Key="Chart.Segment3" Color="{StaticResource Chart.Segment3Color}"/>

    <!-- Status Brushes -->
    <SolidColorBrush x:Key="Status.Success" Color="{StaticResource Status.SuccessColor}"/>
    <SolidColorBrush x:Key="Status.Warning" Color="{StaticResource Status.WarningColor}"/>
    <SolidColorBrush x:Key="Status.Danger" Color="{StaticResource Status.DangerColor}"/>
    <SolidColorBrush x:Key="Status.Info" Color="{StaticResource Status.InfoColor}"/>

    <!-- Selector Brushes -->
    <SolidColorBrush x:Key="Selector.Active" Color="{StaticResource Selector.ActiveColor}"/>
    <SolidColorBrush x:Key="Selector.Inactive" Color="{StaticResource Selector.InactiveColor}"/>

    <!-- ============================================ -->
    <!-- SHADOWS (Pulse: soft, subtle elevation on light) -->
    <!-- ============================================ -->
    <DropShadowEffect x:Key="Shadow.SM" BlurRadius="10" ShadowDepth="4" Direction="270" Opacity="0.06" Color="#1F345C"/>
    <DropShadowEffect x:Key="Shadow.MD" BlurRadius="24" ShadowDepth="8" Direction="270" Opacity="0.12" Color="#1F345C"/>
    <DropShadowEffect x:Key="Shadow.LG" BlurRadius="36" ShadowDepth="14" Direction="270" Opacity="0.16" Color="#1F345C"/>

</ResourceDictionary>
