<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
    ============================================
    CARD STYLES
    v1.7 Design Revamp - Samsung Digital Wellbeing Style
    
    KEY RULES:
    - Corner radius: 20px
    - NO shadows
    - NO borders
    - Generous padding: 20-24px
    ============================================
    -->

    <!-- ============================================ -->
    <!-- BASE CARD STYLE -->
    <!-- ============================================ -->

    <!-- Base Card - Samsung style: 20px radius, no shadow, no border -->
    <Style x:Key="CardBase" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Bg.Card}"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Card}"/>
        <Setter Property="Padding" Value="{DynamicResource Padding.Card}"/>
        <!-- NO shadow, NO border - Samsung style -->
    </Style>

    <!-- ============================================ -->
    <!-- CARD VARIANTS -->
    <!-- ============================================ -->

    <!-- Elevated Card - Same as base (no shadows in Samsung style) -->
    <Style x:Key="CardElevated" TargetType="Border" BasedOn="{StaticResource CardBase}"/>

    <!-- Flat Card - Same as base (no borders in Samsung style) -->
    <Style x:Key="CardFlat" TargetType="Border" BasedOn="{StaticResource CardBase}"/>

    <!-- Stat Card (dashboard) - Main hero card -->
    <Style x:Key="CardStat" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Margin" Value="{DynamicResource Margin.Card}"/>
    </Style>

    <!-- Interactive Card - Subtle hover effect -->
    <Style x:Key="CardInteractive" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Bg.Elevated}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================ -->
    <!-- LIST ITEM CARD -->
    <!-- ============================================ -->

    <!-- List Item - For app/category rows -->
    <Style x:Key="CardListItem" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.SM}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="0,2"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Bg.Elevated}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================ -->
    <!-- ACCENT/STATUS CARDS (Optional left border) -->
    <!-- ============================================ -->

    <!-- Card with Accent left border -->
    <Style x:Key="CardAccented" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Primary}"/>
        <Setter Property="BorderThickness" Value="3,0,0,0"/>
    </Style>

    <!-- Status Cards with colored left border -->
    <Style x:Key="CardSuccess" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="BorderBrush" Value="{DynamicResource Status.Success}"/>
        <Setter Property="BorderThickness" Value="3,0,0,0"/>
    </Style>

    <Style x:Key="CardWarning" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="BorderBrush" Value="{DynamicResource Status.Warning}"/>
        <Setter Property="BorderThickness" Value="3,0,0,0"/>
    </Style>

    <Style x:Key="CardDanger" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="BorderBrush" Value="{DynamicResource Status.Danger}"/>
        <Setter Property="BorderThickness" Value="3,0,0,0"/>
    </Style>

    <!-- ============================================ -->
    <!-- SPECIAL CARDS -->
    <!-- ============================================ -->

    <!-- Content Card - Standard content card with margin -->
    <Style x:Key="CardContent" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Margin" Value="{DynamicResource Margin.Card}"/>
    </Style>

    <!-- Full Width Card - For sections that span full width -->
    <Style x:Key="CardFullWidth" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- Chart Card - Card containing a chart -->
    <Style x:Key="CardChart" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Margin" Value="{DynamicResource Margin.Card}"/>
        <Setter Property="Padding" Value="20,20,20,16"/>
    </Style>

    <!-- Category Card - For category items with icon -->
    <Style x:Key="CardCategory" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Margin" Value="{DynamicResource Margin.Card}"/>
    </Style>

    <!-- ============================================ -->
    <!-- CONTAINER STYLES -->
    <!-- ============================================ -->

    <!-- Inner container for card content sections -->
    <Style x:Key="CardSection" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- Row container for items like "Average | 69 dB" -->
    <Style x:Key="CardRow" TargetType="Grid">
        <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>

</ResourceDictionary>
